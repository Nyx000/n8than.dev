n8than.dev {
	encode gzip
	# security_headers snippet is defined in the box's main /etc/caddy/Caddyfile
	import security_headers
	# CSP in report-only first (n8than.dev only). img-src allows https: for SeedSearch product CDNs.
	# 'unsafe-inline' is required: Astro + the SeedSearch demo both ship inline scripts/styles.
	header Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self'"

	# Live climate slice — proxied from the Pi's own web over Tailscale (the Pi holds the live
	# local DB since the BLE cutover; the box's local Postgres is stale).
	handle /api/grow/live {
		rewrite * /api/public/live
		reverse_proxy https://growtent.taile16d94.ts.net {
			header_up Host growtent.taile16d94.ts.net
		}
		header {
			-Server
			Cache-Control "public, max-age=5"
		}
	}

	# Live tent camera (MJPEG) — same Pi web over Tailscale; concurrency-capped at the Pi.
	# flush_interval -1 disables response buffering so the multipart stream flows frame-by-frame.
	handle /api/grow/cam/stream {
		rewrite * /api/public/cam/stream
		reverse_proxy https://growtent.taile16d94.ts.net {
			header_up Host growtent.taile16d94.ts.net
			flush_interval -1
		}
		header -Server
	}

	# SeedSearch semantic search demo (API + page) -> sdseed-search service
	handle /seedsearch {
		redir * /seedsearch/ permanent
	}
	handle_path /seedsearch/* {
		reverse_proxy 127.0.0.1:3002
		header -Server
	}
	# Back-compat: the demo used to live at /sdsb — redirect old links.
	handle /sdsb {
		redir * /seedsearch/ permanent
	}
	handle /sdsb/* {
		redir * /seedsearch/ permanent
	}

	handle {
		root * /var/www/n8than.dev/dist
		file_server
		header {
			-Server
			Cache-Control "public, max-age=3600"
		}
		@assets path_regexp \.(js|css|jpg|jpeg|png|gif|svg|ico|woff2?|ttf|otf|webp|avif)$
		header @assets Cache-Control "public, max-age=31536000, immutable"
	}
}

# www -> apex redirect (also lets Caddy issue a cert for www, so HSTS includeSubDomains is safe).
# The security_headers snippet is defined in the box's main /etc/caddy/Caddyfile.
www.n8than.dev {
	import security_headers
	redir https://n8than.dev{uri} permanent
}
