---
import BaseLayout from '../layouts/BaseLayout.astro';

const probes = [
  { id: 'canopy', label: 'CANOPY', note: 'at the plant tops — drives VPD', spark: true },
  { id: 'lower', label: 'LOWER TENT', note: 'under the canopy — gradient sentinel', spark: true },
  { id: 'room', label: 'INTAKE AIR', note: 'ambient air feeding the tent', spark: true },
];

// The four readouts per card. `key` selects the contextual definition; `aria` names the
// term for screen readers on the ? trigger.
const metrics = [
  { f: 'tempF', unit: '°F', label: 'temp', key: 'temperature', aria: 'temperature' },
  { f: 'rh', unit: '%', label: 'humidity', key: 'humidity', aria: 'humidity' },
  { f: 'vpdKpa', unit: 'kPa', label: 'VPD', key: 'vpd', aria: 'VPD (vapor pressure deficit)' },
  { f: 'dewF', unit: '°F', label: 'dew point', key: 'dewpoint', aria: 'dew point' },
];

// Tooltip copy — same core meaning, but the "why it matters here" is tuned to each zone.
const defs: Record<string, Record<string, string>> = {
  canopy: {
    temperature: 'Air temp at the leaves, where transpiration happens.',
    humidity: 'Relative humidity at the canopy — moisture the air holds vs. its max at this temp.',
    vpd: 'Vapor Pressure Deficit — how "thirsty" the air is at the leaf; it drives transpiration. The zone that matters most.',
    dewpoint:
      'The temp at which canopy air would condense — how close buds are to wet (mold risk).',
  },
  lower: {
    temperature:
      'Air temp beneath the canopy; compared to canopy temp it reveals vertical stratification.',
    humidity: 'RH down low, where moisture pools — usually higher than the canopy.',
    vpd: 'Vapor Pressure Deficit near the floor — a low-zone check on the gradient.',
    dewpoint:
      'Condensation temp in the coldest, dampest zone — the first place to see condensation.',
  },
  room: {
    temperature: 'Temp of the ambient room air being pulled into the tent.',
    humidity: 'RH of the incoming air — the baseline the tent has to correct.',
    vpd: 'Vapor Pressure Deficit of the intake air, before the tent conditions it.',
    dewpoint: 'Condensation temp of the incoming air.',
  },
};
---

<BaseLayout
  title="Grow Tent Telemetry | n8than.dev"
  description="Live environmental telemetry from a self-built, read-only grow tent monitoring stack."
>
  <section class="container" id="grow-root">
    <div class="heading-row">
      <h1 class="section-heading">Grow Tent Telemetry</h1>
      <span id="grow-pill" class="pill">CONNECTING</span>
    </div>
    <p class="intro">
      Live readings from a self-built monitoring stack running on this same server: a controller in
      a grow tent is polled read-only every 10 seconds, logged to Postgres, and streamed here. Three
      probes — canopy, lower tent, and intake air.
      <span id="grow-updated"></span>
    </p>

    <article class="card cam-card">
      <header class="card-head">
        <h2 class="probe-name">TENT CAMERA</h2>
        <span class="probe-note">live view — capped to a few concurrent viewers</span>
      </header>
      <div class="cam-frame">
        <img id="grow-cam" class="cam-img" alt="live tent camera" />
        <div id="grow-cam-offline" class="cam-overlay" hidden>camera offline · retrying…</div>
      </div>
    </article>

    <div class="grid stagger">
      {
        probes.map((p) => (
          <article class="card" data-probe={p.id}>
            <header class="card-head">
              <h2 class="probe-name">{p.label}</h2>
              <span class="probe-note">{p.note}</span>
            </header>
            <div class="readout">
              {metrics.map((m) => (
                <div class="metric">
                  <span class="value" data-f={m.f}>
                    —
                  </span>
                  <span class="unit">{m.unit}</span>
                  <span class="label">
                    {m.label}
                    <span class="tip">
                      <button
                        type="button"
                        class="tip-btn"
                        aria-label={`What is ${m.aria}?`}
                        aria-describedby={`tip-${p.id}-${m.key}`}
                      >
                        ?
                      </button>
                      <span class="tip-bubble" role="tooltip" id={`tip-${p.id}-${m.key}`}>
                        {defs[p.id][m.key]}
                      </span>
                    </span>
                  </span>
                </div>
              ))}
            </div>
            {p.spark && (
              <>
                <svg
                  class="spark"
                  viewBox="0 0 100 28"
                  preserveAspectRatio="none"
                  aria-hidden="true"
                >
                  <path class="spark-temp" d="" />
                  <path class="spark-rh" d="" />
                </svg>
                <p class="spark-caption">
                  <span class="k k-temp">temp</span> · <span class="k k-rh">RH</span> — last 30 min
                </p>
              </>
            )}
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: 64rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .heading-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border);
    display: inline-block;
  }

  .pill {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    padding: 0.25em 0.7em;
    border: 1px solid var(--color-muted);
    border-radius: 3px;
    color: var(--color-muted);
  }

  .pill.live {
    border-color: var(--color-accent);
    color: var(--color-accent);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .pill.stale {
    border-color: #c9a227;
    color: #c9a227;
  }

  .pill.offline {
    border-color: #b3404a;
    color: #b3404a;
  }

  @keyframes pulse {
    50% {
      opacity: 0.55;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill.live {
      animation: none;
    }
  }

  .intro {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-top: calc(-0.5 * var(--space-lg));
    margin-bottom: var(--space-lg);
  }

  #grow-updated {
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    transition: border-color 0.25s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
  }

  .card-head {
    margin-bottom: var(--space-md);
  }

  .probe-name {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0;
  }

  .probe-note {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .readout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-sm);
  }

  .metric {
    position: relative;
    display: grid;
    grid-template-columns: auto auto;
    grid-template-rows: auto auto;
    align-items: baseline;
    column-gap: 0.25em;
  }

  /* "?" definition tooltip — CSS-first: reveals on hover (desktop), focus (keyboard),
     and tap (the button takes focus on touch, triggering :focus-within). */
  .tip {
    position: static;
    display: inline-flex;
    margin-left: 0.3em;
  }

  .tip-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15em;
    height: 1.15em;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: 50%;
    cursor: help;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .tip-btn:hover,
  .tip-btn:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    outline: none;
  }

  .tip-bubble {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 5;
    width: max-content;
    max-width: min(240px, 70vw);
    margin-top: 0.4em;
    padding: 0.5em 0.65em;
    font-size: 0.72rem;
    line-height: 1.35;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  /* Right-column metrics: grow the bubble leftward so it stays inside the card. */
  .metric:nth-child(even) .tip-bubble {
    left: auto;
    right: 0;
  }

  .tip:hover .tip-bubble,
  .tip:focus-within .tip-bubble {
    opacity: 1;
    visibility: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .tip-btn,
    .tip-bubble {
      transition: none;
    }
  }

  .value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-text);
  }

  .offline .value {
    color: var(--color-muted);
  }

  .unit {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .label {
    grid-column: 1 / -1;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .spark {
    width: 100%;
    height: 56px;
    margin-top: var(--space-md);
    display: block;
  }

  .spark path {
    fill: none;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .spark-temp {
    stroke: var(--color-accent);
  }

  .spark-rh {
    stroke: var(--color-muted);
  }

  .spark-caption {
    font-size: 0.7rem;
    color: var(--color-muted);
    margin: var(--space-sm) 0 0;
  }

  .k-temp {
    color: var(--color-accent);
  }

  .cam-card {
    margin-bottom: var(--space-lg);
  }

  .cam-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-top: var(--space-md);
    background: #0b0b0b;
    border-radius: 8px;
    overflow: hidden;
  }

  .cam-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .cam-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: rgba(0, 0, 0, 0.45);
  }

  .cam-overlay[hidden] {
    display: none;
  }
</style>

<script>
  interface PublicSensor {
    tempF: number | null;
    rh: number | null;
    vpdKpa: number | null;
    dewF: number | null;
  }
  interface SparkPoint {
    t: number;
    tempF: number | null;
    rh: number | null;
    vpd: number | null;
  }
  interface PublicLive {
    ts: number | null;
    freshness: 'live' | 'stale' | 'none';
    sensors: Record<'canopy' | 'lower' | 'room', PublicSensor | null>;
    spark: Record<'canopy' | 'lower' | 'room', SparkPoint[]>;
  }

  const POLL_MS = 10_000;
  let timer: number | undefined;
  let failures = 0;
  let lastTs: number | null = null;

  const fmt = (v: number | null, digits = 1) => (v == null ? '—' : v.toFixed(digits));

  function setPill(state: '' | 'live' | 'stale' | 'offline', text: string) {
    const pill = document.getElementById('grow-pill');
    if (!pill) return;
    pill.className = state ? `pill ${state}` : 'pill';
    pill.textContent = text;
  }

  function renderProbe(id: string, s: PublicSensor | null) {
    const card = document.querySelector(`[data-probe="${id}"]`);
    if (!card) return;
    const fields: Array<[keyof PublicSensor, number]> = [
      ['tempF', 1],
      ['rh', 1],
      ['vpdKpa', 2],
      ['dewF', 1],
    ];
    for (const [key, digits] of fields) {
      const el = card.querySelector(`[data-f="${key}"]`);
      if (el) el.textContent = s ? fmt(s[key], digits) : '—';
    }
  }

  // One smooth path per series, each normalized to its own min..max (with a little
  // headroom) so shape is visible regardless of absolute scale. The line is a Catmull-Rom
  // spline so sparse/jagged probes (lower, room — intermittent BLE cadence) read as a
  // trend curve instead of zig-zags. It still passes through every real reading: the
  // smoothing only shapes the segments between points, it never invents data in the gaps.
  function splinePath(pts: SparkPoint[], pick: (p: SparkPoint) => number | null): string {
    const xs = pts.map(pick);
    const valid = xs.filter((v): v is number => v != null);
    if (valid.length < 2 || pts.length < 2) return '';
    const lo = Math.min(...valid);
    const hi = Math.max(...valid);
    const pad = Math.max((hi - lo) * 0.15, 0.1);
    const t0 = pts[0].t;
    const t1 = pts[pts.length - 1].t;
    const span = Math.max(t1 - t0, 1);
    const pxy = pts
      .map((p, i) => {
        const v = xs[i];
        if (v == null) return null;
        return {
          x: ((p.t - t0) / span) * 100,
          y: 28 - ((v - (lo - pad)) / (hi - lo + 2 * pad)) * 28,
        };
      })
      .filter((q): q is { x: number; y: number } => q != null);
    if (pxy.length < 2) return '';
    // Catmull-Rom → cubic Bézier control points; clamp control-y into [0,28] so the curve
    // can't overshoot the viewBox and get clipped at the peaks.
    const clampY = (y: number) => Math.max(0, Math.min(28, y));
    const f = (n: number) => n.toFixed(2);
    let d = `M ${f(pxy[0].x)},${f(pxy[0].y)}`;
    for (let i = 0; i < pxy.length - 1; i++) {
      const p0 = pxy[i - 1] ?? pxy[i];
      const p1 = pxy[i];
      const p2 = pxy[i + 1];
      const p3 = pxy[i + 2] ?? pxy[i + 1];
      const c1x = p1.x + (p2.x - p0.x) / 6;
      const c1y = clampY(p1.y + (p2.y - p0.y) / 6);
      const c2x = p2.x - (p3.x - p1.x) / 6;
      const c2y = clampY(p2.y - (p3.y - p1.y) / 6);
      d += ` C ${f(c1x)},${f(c1y)} ${f(c2x)},${f(c2y)} ${f(p2.x)},${f(p2.y)}`;
    }
    return d;
  }

  function renderSpark(id: 'canopy' | 'lower' | 'room', pts: SparkPoint[]) {
    const svg = document.querySelector(`[data-probe="${id}"] svg.spark`);
    if (!svg) return;
    svg.querySelector('.spark-temp')?.setAttribute(
      'd',
      splinePath(pts, (p) => p.tempF),
    );
    svg.querySelector('.spark-rh')?.setAttribute(
      'd',
      splinePath(pts, (p) => p.rh),
    );
  }

  function renderUpdated() {
    const el = document.getElementById('grow-updated');
    if (!el) return;
    if (lastTs == null) {
      el.textContent = '';
      return;
    }
    const age = Math.max(0, Math.round((Date.now() - lastTs) / 1000));
    el.textContent = `Last reading ${age}s ago.`;
  }

  async function tick() {
    const root = document.getElementById('grow-root');
    if (!root) return;
    try {
      const res = await fetch('/api/grow/live', { cache: 'no-store' });
      if (!res.ok) throw new Error(String(res.status));
      const d = (await res.json()) as PublicLive;
      failures = 0;
      lastTs = d.ts;
      renderProbe('canopy', d.sensors.canopy);
      renderProbe('lower', d.sensors.lower);
      renderProbe('room', d.sensors.room);
      renderSpark('canopy', d.spark.canopy);
      renderSpark('lower', d.spark.lower);
      renderSpark('room', d.spark.room);
      root.classList.remove('offline');
      if (d.freshness === 'live') setPill('live', 'LIVE');
      else if (d.freshness === 'stale') setPill('stale', 'STALE');
      else setPill('', 'NO DATA');
    } catch {
      failures += 1;
      if (failures >= 2) {
        setPill('offline', 'OFFLINE');
        root.classList.add('offline');
      }
    }
    renderUpdated();
  }

  function stop() {
    if (timer != null) clearInterval(timer);
    timer = undefined;
  }

  function start() {
    stop();
    void tick();
    timer = window.setInterval(tick, POLL_MS);
  }

  // Live MJPEG camera. The stream never "ends", so 'load' fires on the first frame (hide the
  // overlay) and 'error' fires if it's offline or at the viewer cap (show overlay, retry with a
  // cache-busting param). src is set AFTER the listeners attach so the first event can't be missed.
  let camRetry: number | undefined;
  function setupCam() {
    const cam = document.getElementById('grow-cam') as HTMLImageElement | null;
    const overlay = document.getElementById('grow-cam-offline');
    if (!cam || !overlay) return;
    cam.addEventListener('load', () => {
      overlay.hidden = true;
    });
    cam.addEventListener('error', () => {
      overlay.hidden = false;
      if (camRetry != null) clearTimeout(camRetry);
      camRetry = window.setTimeout(() => {
        cam.src = `/api/grow/cam/stream?t=${Date.now()}`;
      }, 5000);
    });
    cam.src = '/api/grow/cam/stream';
  }

  // ClientRouter is active: init on every page load, stop when leaving /grow or
  // when the tab is hidden.
  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('grow-root')) {
      start();
      setupCam();
    } else stop();
  });

  document.addEventListener('visibilitychange', () => {
    if (!document.getElementById('grow-root')) return;
    if (document.hidden) stop();
    else start();
  });
</script>
