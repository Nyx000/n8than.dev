---
import BaseLayout from '../layouts/BaseLayout.astro';

const probes = [
  { id: 'canopy', label: 'CANOPY', note: 'at the plant tops — drives VPD' },
  { id: 'lower', label: 'LOWER TENT', note: 'under the canopy — gradient sentinel' },
  { id: 'room', label: 'INTAKE AIR', note: 'ambient air feeding the tent' },
];

// The four readouts per card. `key` selects the contextual definition; `aria` names the
// term for screen readers on the ? trigger.
const metrics = [
  { f: 'tempF', unit: '°F', label: 'temp', key: 'temperature', aria: 'temperature' },
  { f: 'rh', unit: '%', label: 'humidity', key: 'humidity', aria: 'humidity' },
  { f: 'vpdKpa', unit: 'kPa', label: 'VPD', key: 'vpd', aria: 'VPD (vapor pressure deficit)' },
  { f: 'dewF', unit: '°F', label: 'dew point', key: 'dewpoint', aria: 'dew point' },
];

// Tooltip copy — same core meaning, but the "why it matters here" is tuned to each zone.
const defs: Record<string, Record<string, string>> = {
  canopy: {
    temperature: 'Air temp at the leaves, where transpiration happens.',
    humidity: 'Relative humidity at the canopy — moisture the air holds vs. its max at this temp.',
    vpd: 'Vapor Pressure Deficit — how "thirsty" the air is at the leaf; it drives transpiration. The zone that matters most.',
    dewpoint:
      'The temp at which canopy air would condense — how close buds are to wet (mold risk).',
  },
  lower: {
    temperature:
      'Air temp beneath the canopy; compared to canopy temp it reveals vertical stratification.',
    humidity: 'RH down low, where moisture pools — usually higher than the canopy.',
    vpd: 'Vapor Pressure Deficit near the floor — a low-zone check on the gradient.',
    dewpoint:
      'Condensation temp in the coldest, dampest zone — the first place to see condensation.',
  },
  room: {
    temperature: 'Temp of the ambient room air being pulled into the tent.',
    humidity: 'RH of the incoming air — the baseline the tent has to correct.',
    vpd: 'Vapor Pressure Deficit of the intake air, before the tent conditions it.',
    dewpoint: 'Condensation temp of the incoming air.',
  },
};
---

<BaseLayout
  title="Grow Tent Telemetry | n8than.dev"
  description="Live environmental telemetry from a self-built, read-only grow tent monitoring stack."
>
  <section class="container" id="grow-root">
    <div class="heading-row">
      <h1 class="section-heading">Grow Tent Telemetry</h1>
      <span id="grow-pill" class="pill is-connecting">CONNECTING</span>
      <span id="grow-updated" class="updated"></span>
      <span id="grow-phase-badge" class="phase-badge" hidden></span>
      <span id="grow-season-badge" class="phase-badge" hidden></span>
    </div>
    <p class="intro">
      Live readings from a self-built monitoring stack running on this same server: a controller in
      a grow tent is polled read-only every 10 seconds, logged to Postgres, and streamed here. Three
      probes — canopy, lower tent, and intake air.
    </p>

    <div class="cluster stagger">
      {
        probes.map((p) => (
          <article class="zone" data-probe={p.id}>
            <header class="zone-head">
              <h2 class="probe-name">{p.label}</h2>
              <span class="probe-note">{p.note}</span>
            </header>
            <div class="readout">
              {metrics.map((m) => (
                <div class="metric">
                  <span class="value" data-f={m.f}>
                    —
                  </span>
                  <span class="unit">{m.unit}</span>
                  <span class="label">
                    {m.label}
                    <span class="tip">
                      <button
                        type="button"
                        class="tip-btn"
                        aria-label={`What is ${m.aria}?`}
                        aria-describedby={`tip-${p.id}-${m.key}`}
                      >
                        ?
                      </button>
                      <span class="tip-bubble" role="tooltip" id={`tip-${p.id}-${m.key}`}>
                        {defs[p.id][m.key]}
                      </span>
                    </span>
                  </span>
                </div>
              ))}
            </div>
            {/* VPD sparkline — drawn from the `spark` history the API already ships.
                Desktop-only (≥720); the mobile strip stays compact. */}
            <div class="spark-wrap">
              <svg
                class="spark"
                viewBox="0 0 120 28"
                preserveAspectRatio="none"
                aria-hidden="true"
                focusable="false"
              >
                <polyline class="spark-line" data-spark={p.id} fill="none" points="" />
              </svg>
              <span class="spark-cap">VPD · recent</span>
            </div>
          </article>
        ))
      }
    </div>

    <article class="card equip-card" id="grow-equip">
      <header class="card-head equip-head">
        <h2 class="probe-name">EQUIPMENT</h2>
        <span class="probe-note">what's running — tap a row for the why</span>
      </header>
      <ul class="equip-list" id="equip-list">
        <li class="equip-sys">connecting…</li>
      </ul>
    </article>

    <article class="card cam-card">
      <header class="card-head">
        <h2 class="probe-name">TENT CAMERA</h2>
      </header>
      <div class="cam-frame">
        <img id="grow-cam" class="cam-img" alt="live tent camera" />
        <div id="grow-cam-loading" class="cam-overlay cam-loading">
          <span class="cam-spinner" aria-hidden="true"></span>
          connecting to camera…
        </div>
        <div id="grow-cam-offline" class="cam-overlay" hidden>camera offline · retrying…</div>
        <div id="grow-cam-night" class="cam-night-note" hidden>
          🌙 lights out — it's meant to be dark in there
        </div>
        <button
          id="grow-cam-fs"
          class="cam-fs-btn"
          type="button"
          aria-label="Fullscreen camera"
          title="Fullscreen"
        >
          <svg class="fs-enter" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"
            ></path>
          </svg>
          <svg class="fs-exit" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"
            ></path>
          </svg>
        </button>
      </div>
    </article>

    <article class="card chatter-card" id="grow-chatter">
      <header class="chatter-head">
        <h2 class="chatter-title">TENT CHATTER</h2>
        <span class="chatter-topic" id="chatter-count-note">#grow-tent</span>
      </header>
      <ol
        class="chatter-log"
        id="chatter-log"
        role="log"
        aria-live="polite"
        aria-label="recent shouts"
        aria-busy="false"
      >
        <li class="chatter-sys">*** connecting to #grow-tent…</li>
      </ol>
      <form class="chatter-form" id="chatter-form" autocomplete="off">
        <textarea
          id="chatter-body"
          class="chatter-input"
          name="body"
          rows="2"
          maxlength="280"
          placeholder="leave a shout…"
          required
          autocomplete="off"
          aria-label="your shout"></textarea>
        <div class="chatter-meta">
          <input
            id="chatter-name"
            class="chatter-name"
            name="name"
            type="text"
            maxlength="32"
            placeholder="anon"
            autocomplete="off"
            aria-label="name (optional)"
          />
          <input
            id="chatter-hp"
            class="chatter-hp"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <span class="chatter-count" id="chatter-count" aria-hidden="true">280</span>
          <button type="submit" class="chatter-post" id="chatter-post">transmit</button>
        </div>
        <p class="chatter-status" id="chatter-status" role="status" aria-live="polite"></p>
      </form>
    </article>
  </section>
</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: 64rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .heading-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* .section-heading now comes from the global utility (--text-h1 clamp). Any
     grow-only override must be #grow-root-scoped for deterministic specificity. */

  /* The status pill uses the global shape-encoded .pill (global.css) — the dot
     shape carries the state, so no page-local pill rules remain here. */

  .updated {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .intro {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-top: calc(-0.5 * var(--space-lg));
    margin-bottom: var(--space-lg);
    max-width: 65ch;
  }

  /* The instrument cluster. On phones the three zones read as ONE panel — a single
     bordered console with hairline dividers, no inter-card gaps, no graphs — so the
     whole readout sits compact above the camera. At 720px the panel dissolves and each
     zone becomes its own card in a 3-up row. */
  .cluster {
    margin-bottom: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .zone {
    padding: var(--space-md) var(--space-lg);
  }

  .zone + .zone {
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 720px) {
    .cluster {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
      background: transparent;
      border: 0;
      border-radius: 0;
    }

    .zone {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 10px;
      transition: border-color 0.25s ease;
    }

    .zone + .zone {
      border-top: 1px solid var(--color-border);
    }

    .zone:hover {
      border-color: var(--color-accent);
    }
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    transition: border-color 0.25s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
  }

  .card-head,
  .zone-head {
    margin-bottom: var(--space-md);
  }

  .probe-name {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0;
  }

  .probe-note {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .readout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-sm);
  }

  .metric {
    position: relative;
    display: grid;
    grid-template-columns: auto auto;
    grid-template-rows: auto auto;
    align-items: baseline;
    column-gap: 0.25em;
  }

  /* "?" definition tooltip — CSS-first: reveals on hover (desktop), focus (keyboard),
     and tap (the button takes focus on touch, triggering :focus-within). */
  .tip {
    position: static;
    display: inline-flex;
    margin-left: 0.3em;
  }

  .tip-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15em;
    height: 1.15em;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: 50%;
    cursor: help;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .tip-btn:hover,
  .tip-btn:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    outline: none;
  }

  .tip-bubble {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 5;
    width: max-content;
    max-width: min(240px, 70vw);
    margin-top: 0.4em;
    padding: 0.5em 0.65em;
    font-size: 0.72rem;
    line-height: 1.35;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  /* Right-column metrics: grow the bubble leftward so it stays inside the card. */
  .metric:nth-child(even) .tip-bubble {
    left: auto;
    right: 0;
  }

  .tip:hover .tip-bubble,
  .tip:focus-within .tip-bubble {
    opacity: 1;
    visibility: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .tip-btn,
    .tip-bubble {
      transition: none;
    }
  }

  .value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-text);
    min-width: 4ch; /* reserve width so the first real reading doesn't shift layout */
  }

  /* Amber tick when a reading actually changes (JS adds .tick, then it self-clears). */
  .value.tick {
    animation: value-tick 0.6s var(--ease-out);
  }

  @keyframes value-tick {
    0% {
      color: var(--color-warn);
    }
    100% {
      color: var(--color-text);
    }
  }

  /* Stale or offline data reads dimmer — opacity (not colour) so the amber tick
     and the value's own colour are preserved. */
  #grow-root.stale .value,
  .offline .value {
    opacity: 0.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .value.tick {
      animation: none;
    }
  }

  /* VPD sparkline — desktop only; the mobile strip stays compact (KEEP list). */
  .spark-wrap {
    display: none;
  }

  @media (min-width: 720px) {
    .spark-wrap {
      display: block;
      margin-top: var(--space-sm);
      padding-top: var(--space-sm);
      border-top: 1px solid var(--color-border);
    }
    .spark {
      display: block;
      width: 100%;
      height: 28px;
    }
    .spark-line {
      fill: none;
      stroke: var(--color-accent);
      stroke-width: 1.5;
      vector-effect: non-scaling-stroke;
      stroke-linejoin: round;
      stroke-linecap: round;
    }
    .spark-cap {
      display: block;
      margin-top: 0.25rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-muted);
    }
  }

  .unit {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .label {
    grid-column: 1 / -1;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .cam-card {
    margin-bottom: var(--space-lg);
  }

  /* On wide screens, let the camera break out of the 64rem text column to fill more of the
     viewport (e.g. a 1440p display). The page container is viewport-centered, so left:50% +
     translateX(-50%) re-centers a wider card on the viewport; the readouts stay at 64rem. */
  @media (min-width: 1080px) {
    .cam-card {
      position: relative;
      left: 50%;
      width: min(94vw, 1920px);
      transform: translateX(-50%);
    }
  }

  .cam-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-top: var(--space-md);
    background: #0b0b0b;
    border-radius: 8px;
    overflow: hidden;
  }

  .cam-img {
    /* Absolutely fill the frame so the feed covers it edge-to-edge in every case — a
       percentage height won't resolve against the flex-sized frame on mobile, which would
       letterbox the 16:9 feed inside the taller frame. cover (not contain) keeps the plant
       the dominant object; center keeps the canopy in frame. */
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .cam-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: rgba(0, 0, 0, 0.45);
  }

  .cam-overlay[hidden] {
    display: none;
  }

  /* First-load state: a solid fill over the void with a spinning ring, until the first
     MJPEG frame arrives (cleared on 'load') or the feed errors (offline overlay takes over). */
  .cam-loading {
    flex-direction: column;
    gap: 0.85rem;
    background: #0b0b0b;
  }

  .cam-spinner {
    width: 2.25rem;
    height: 2.25rem;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: cam-spin 0.8s linear infinite;
  }

  @keyframes cam-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cam-spinner {
      animation: none;
      border-top-color: var(--color-accent);
      opacity: 0.6;
    }
  }

  .cam-fs-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    padding: 0;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    cursor: pointer;
    opacity: 0.55;
    transition:
      opacity 0.2s ease,
      background 0.2s ease;
  }

  .cam-frame:hover .cam-fs-btn,
  .cam-fs-btn:focus-visible {
    opacity: 1;
    outline: none;
  }

  .cam-fs-btn:hover {
    background: rgba(0, 0, 0, 0.72);
  }

  .cam-fs-btn svg {
    width: 1.3rem;
    height: 1.3rem;
  }

  .cam-fs-btn .fs-exit {
    display: none;
  }

  .cam-frame.is-fs .cam-fs-btn .fs-enter {
    display: none;
  }

  .cam-frame.is-fs .cam-fs-btn .fs-exit {
    display: inline;
  }

  /* CSS "fill the viewport" fallback for browsers without element fullscreen (iPhone Safari
     on an <img>). Native fullscreen (desktop, Android) is handled by the :fullscreen rules. */
  .cam-frame.cam-pseudo-fs {
    position: fixed;
    inset: 0;
    z-index: 1000;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    margin: 0;
    aspect-ratio: auto;
    border-radius: 0;
  }

  /* In any fullscreen mode, show the whole feed (no crop) and let it fill the screen. */
  .cam-frame.cam-pseudo-fs .cam-img,
  .cam-frame:fullscreen .cam-img,
  .cam-frame:-webkit-full-screen .cam-img {
    object-fit: contain;
  }

  .cam-frame:fullscreen,
  .cam-frame:-webkit-full-screen {
    width: 100vw;
    height: 100vh;
    aspect-ratio: auto;
    border-radius: 0;
  }

  .equip-card {
    margin-bottom: var(--space-lg);
  }

  .equip-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .phase-badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-warn);
    white-space: nowrap;
  }

  .cam-night-note {
    position: absolute;
    left: 0.6rem;
    bottom: 0.6rem;
    z-index: 2;
    padding: 0.3em 0.6em;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    background: rgba(0, 0, 0, 0.55);
    border-radius: 5px;
  }

  .cam-night-note[hidden] {
    display: none;
  }

  /* Phone: the whole page is one viewport with the camera as the hero. Each zone collapses
     from a 2×2 card into a single tight row — the label on the left, its four readings inline
     — so all three zones stack into a short strip. The intro prose, per-zone notes, and the
     "?" tooltips are desktop-only here; the readings speak for themselves and every saved pixel
     goes to the video. The camera then flexes to claim the rest of the screen. */
  @media (max-width: 719px) {
    #grow-root {
      display: flex;
      flex-direction: column;
      /* Subtract the header + footer so the section ≈ the remaining screen, no long scroll. */
      min-height: calc(100dvh - 11rem);
      padding-top: var(--space-md);
      padding-bottom: var(--space-md);
    }

    /* Font-size comes from the global --text-h1 clamp; only the tighter mobile
       spacing is overridden (scoped to #grow-root for deterministic specificity). */
    #grow-root .section-heading {
      margin-bottom: var(--space-sm);
      padding-bottom: var(--space-sm);
    }

    .intro {
      display: none;
    }

    .cluster {
      margin-bottom: var(--space-md);
    }

    /* name | four readings, on one line */
    .zone {
      display: grid;
      grid-template-columns: 4.25rem 1fr;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
    }

    .zone-head {
      margin-bottom: 0;
    }

    .probe-note {
      display: none;
    }

    .probe-name {
      font-size: 0.72rem;
      line-height: 1.15;
    }

    .readout {
      grid-template-columns: repeat(4, 1fr);
      gap: 0 var(--space-sm);
    }

    .value {
      font-size: 0.95rem;
    }

    .unit {
      font-size: 0.6rem;
    }

    .label {
      font-size: 0.5rem;
    }

    /* Tooltips are a desktop affordance; on a phone they'd be untappably small and steal room. */
    .tip {
      display: none;
    }

    /* Camera eats the rest of the column — the plant is the hero. */
    .cam-card {
      flex: 1;
      display: flex;
      flex-direction: column;
      margin-bottom: 0;
    }

    .cam-frame {
      flex: 1;
      min-height: 58svh; /* svh: excludes mobile URL bar so the feed doesn't overflow */
      aspect-ratio: auto;
    }

    .equip-card {
      order: 1;
      margin-bottom: 0;
      margin-top: var(--space-md);
    }

    .chatter-card {
      order: 2;
    }
  }

  /* ≤374px: the four-up readout can't shrink below its min-content (~224px) in the
     ~180px of usable width → the whole page scrolls sideways. Reflow to 2×2 so each
     reading keeps its room. Placed after the ≤719 block so it wins on narrow phones. */
  @media (max-width: 374px) {
    .readout {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm) var(--space-sm);
    }
  }
</style>
<style is:global>
  /* ============================================================
     TENT CHATTER — an amber-phosphor IRC terminal embedded in the
     dashboard. Stays in the page's HL2-orange palette but treats the
     whole panel like a lit CRT screen (recessed warm bg, scanlines,
     phosphor glow). GLOBAL on purpose: the log rows are created in JS,
     so Astro's scoped CSS would miss them. Every selector is uniquely
     named, so global scope leaks nothing.
     ============================================================ */
  #grow-chatter.chatter-card {
    --crt-fg: var(--color-text); /* warm off-white message text */
    --crt-amber: var(--color-accent); /* HL2 orange phosphor */
    --crt-dim: #9c8f7d; /* warm dim — clears 4.5:1 on the screen bg */
    --crt-screen: #0b0907; /* recessed warm near-black screen */
    --crt-line: #241c14; /* warm screen border */
    --crt-glow: rgba(255, 102, 0, 0.35);
    position: relative;
    overflow: hidden;
    background: var(--crt-screen);
    border-color: var(--crt-line);
  }

  #grow-chatter.chatter-card:hover {
    border-color: var(--crt-amber);
  }

  /* scanlines over the whole screen — moderate, kept readable. pointer-events
     none so the form underneath stays clickable. */
  #grow-chatter::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0) 0px,
      rgba(0, 0, 0, 0) 3px,
      rgba(0, 0, 0, 0.02) 3px,
      rgba(0, 0, 0, 0.02) 4px
    );
  }

  /* content above the overlays */
  #grow-chatter > * {
    position: relative;
    z-index: 1;
  }

  .chatter-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }

  .chatter-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.14em;
    color: var(--crt-amber);
    text-shadow: 0 0 7px var(--crt-glow);
  }

  .chatter-topic {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--crt-dim);
  }

  /* the scrollable screen region */
  .chatter-log {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0.3rem 0;
    min-height: 5rem;
    max-height: 34rem;
    overflow-y: auto;
    overflow-anchor: none; /* prepend must not yank the scroll */
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.45;
    color: var(--crt-fg);
    text-shadow: 0 0 3px rgba(255, 102, 0, 0.12); /* phosphor bloom */
    border-top: 1px solid var(--crt-line);
    border-bottom: 1px solid var(--crt-line);
    scrollbar-width: thin;
    scrollbar-color: var(--crt-line) var(--crt-screen);
  }

  /* IRC row: HH:MM <nick> message — time + nick fixed, message wraps with a
     hanging indent (it stays in its own flex column). */
  .chatter-line {
    display: flex;
    gap: 0.5em;
    align-items: baseline;
    padding: 0.13rem 0.45rem;
  }

  .chatter-line:nth-child(odd) {
    background: rgba(255, 140, 40, 0.04); /* zebra — differentiate rows */
  }

  .chatter-time {
    flex: none;
    color: var(--crt-dim);
    font-variant-numeric: tabular-nums;
  }

  .chatter-nick {
    flex: none;
    font-weight: 500;
    /* per-user hue set inline in JS; this is the fallback */
    color: var(--crt-amber);
  }

  .chatter-msg {
    flex: 1;
    min-width: 0;
    word-break: break-word;
  }

  /* mIRC-style system + empty lines */
  .chatter-sys {
    padding: 0.13rem 0.45rem;
    color: var(--crt-dim);
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .chatter-line.is-new {
      animation: chatter-in 0.18s ease both;
    }
  }

  @keyframes chatter-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ----- compose bar ----- */
  .chatter-form {
    margin-top: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .chatter-input,
  .chatter-name {
    width: 100%;
    padding: 0.5em 0.6em;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--crt-fg);
    background: #070504;
    border: 1px solid var(--crt-line);
    border-radius: 5px;
    text-shadow: 0 0 3px rgba(255, 102, 0, 0.12);
  }

  .chatter-input {
    resize: vertical;
  }

  .chatter-input::placeholder,
  .chatter-name::placeholder {
    color: #7a6f5e;
  }

  .chatter-input:focus,
  .chatter-name:focus {
    outline: none;
    border-color: var(--crt-amber);
    box-shadow:
      0 0 0 1px var(--crt-amber),
      0 0 10px rgba(255, 102, 0, 0.25);
  }

  .chatter-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .chatter-name {
    flex: 1;
    min-width: 0;
  }

  .chatter-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--crt-dim);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .chatter-count.is-warn {
    color: var(--crt-amber);
  }

  .chatter-count.is-over {
    color: #ff5a5a;
  }

  .chatter-post {
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.45em 1.1em;
    color: var(--crt-amber);
    background: transparent;
    border: 1px solid var(--crt-amber);
    border-radius: 5px;
    cursor: pointer;
    text-shadow: 0 0 6px var(--crt-glow);
    transition:
      background 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .chatter-post:hover {
    background: var(--crt-amber);
    color: #0b0907;
    text-shadow: none;
    box-shadow: 0 0 12px rgba(255, 102, 0, 0.5);
  }

  .chatter-post:focus-visible {
    outline: 2px solid var(--crt-amber);
    outline-offset: 2px;
  }

  .chatter-post:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .chatter-status {
    min-height: 1em;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--crt-dim);
  }

  .chatter-status.is-error {
    color: #ff5a5a;
  }

  .chatter-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  /* Mobile: the plant is the hero. Trim the chatter's padding and cap the log
     short so the camera claims the screen; the box sits compact below it. */
  @media (max-width: 719px) {
    #grow-chatter.chatter-card {
      padding: 0.55rem 0.65rem;
      margin-bottom: 0;
    }

    .chatter-log {
      max-height: 9rem;
      margin-top: 0.45rem;
    }

    .chatter-form {
      margin-top: 0.45rem;
    }

    .chatter-title {
      font-size: 0.85rem;
    }
  }

  /* ============================================================
     EQUIPMENT — JS-created rows (global scope like the chatter log).
     One tappable line per device; expanded detail below it.
     ============================================================ */
  .equip-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .equip-row + .equip-row {
    border-top: 1px solid var(--color-border);
  }

  .equip-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap; /* the rule sentence WRAPS — never truncates */
    gap: 0.25rem 0.6rem;
    width: 100%;
    padding: 0.55rem 0.2rem;
    font: inherit;
    text-align: left;
    color: var(--color-text);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .equip-line:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .equip-dot {
    flex: none;
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    background: var(--color-muted);
    align-self: center;
  }

  .equip-dot.is-on {
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(255, 102, 0, 0.6);
  }

  .equip-dot.is-off {
    background: #3a3a40;
  }

  .equip-name {
    flex: none;
    font-family: var(--font-display);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
  }

  .equip-state {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    padding: 0.1em 0.5em;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .equip-state.is-on {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .equip-rule {
    flex: 1 1 14rem;
    min-width: 0;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .equip-chev {
    flex: none;
    margin-left: auto;
    color: var(--color-muted);
    transition: transform 0.2s ease;
  }

  .equip-line[aria-expanded='true'] .equip-chev {
    transform: rotate(180deg);
  }

  .equip-detail {
    padding: 0 0.2rem 0.7rem 1.35rem;
    font-size: 0.82rem;
  }

  .equip-why {
    margin: 0 0 0.35rem;
    color: var(--color-text);
  }

  .equip-facts {
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .equip-facts li + li {
    margin-top: 0.15rem;
  }

  .equip-sys {
    padding: 0.55rem 0.2rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
    font-style: italic;
  }

  /* Stale/offline dims equipment like the sensor values */
  #grow-root.stale .equip-dot,
  #grow-root.stale .equip-state,
  #grow-root.offline .equip-dot,
  #grow-root.offline .equip-state {
    opacity: 0.55;
  }

  /* ============================================================
     NIGHT THEME — lights-off in the tent dims the whole page a step
     and warms/softens the accent. Driven by JS setting
     data-grow-phase="night" on <html>; day is the default palette.
     ============================================================ */
  html[data-grow-phase='night'] {
    --color-bg: #060606;
    --color-surface: #0d0c0b;
    --color-border: #1a1917;
    --color-accent: #c96a1a;
    --color-accent-hover: #db8438;
    --color-text: #c2bcb0;
    --color-muted: #7d7d84;
  }

  html[data-grow-phase] body {
    transition:
      background-color 1s ease,
      color 1s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    html[data-grow-phase] body {
      transition: none;
    }
  }
</style>

<script>
  import {
    ruleLine,
    whyLine,
    detailLines,
    phaseBadge,
    noticeLine,
    type PublicEquipment,
    type EquipmentSensors,
  } from '../lib/grow-equipment';

  // Public seasonal-hint sprinkle. Mirrors growtent web/lib/public-weather.ts EXACTLY
  // (the repos share no code) — no numbers, no place name, no coordinates.
  interface PublicNotice {
    conditions: 'warm_spell' | 'humid_spell' | 'nominal' | null;
    note: string | null;
  }

  interface PublicSensor {
    tempF: number | null;
    rh: number | null;
    vpdKpa: number | null;
    dewF: number | null;
  }
  interface SparkPoint {
    t: number;
    tempF: number;
    rh: number;
    vpd: number;
  }
  interface PublicLive {
    ts: number | null;
    freshness: 'live' | 'stale' | 'none';
    sensors: Record<'canopy' | 'lower' | 'room', PublicSensor | null>;
    // The API already ships per-zone history; the frontend used to discard it.
    spark?: Record<'canopy' | 'lower' | 'room', SparkPoint[]>;
    // Backend addition (grow repo, ships independently); rendered only once present.
    targets?: { vpdLow: number; vpdHigh: number };
    // Equipment slice (grow repo ships it first; optional so an older API is tolerated).
    equipment?: PublicEquipment[];
    lightPhase?: 'day' | 'night' | null;
    nextPhaseChange?: number | null;
    // Seasonal-hint sprinkle (grow repo ships it independently; optional so an older
    // API is tolerated). null/absent → no badge.
    notice?: PublicNotice | null;
  }

  // 5s matches the API's max-age=5 cache; the sensor cadence is slower (~1/min), so this
  // mainly smooths the "Xs ago" counter and freshness pill rather than fetching newer data.
  const POLL_MS = 5_000;
  let timer: number | undefined;
  let failures = 0;
  let lastTs: number | null = null;

  const fmt = (v: number | null, digits = 1) => (v == null ? '—' : v.toFixed(digits));

  // Pill state maps to the global shape-encoded .pill (dot shape carries the state,
  // so it reads under reduced-motion + colour-blindness). 'none' → connecting look.
  function setPill(state: 'connecting' | 'live' | 'stale' | 'offline' | 'none', text: string) {
    const pill = document.getElementById('grow-pill');
    if (!pill) return;
    pill.className = `pill is-${state === 'none' ? 'connecting' : state}`;
    pill.textContent = text;
  }

  function renderProbe(id: string, s: PublicSensor | null) {
    const card = document.querySelector(`[data-probe="${id}"]`);
    if (!card) return;
    const fields: Array<[keyof PublicSensor, number]> = [
      ['tempF', 1],
      ['rh', 1],
      ['vpdKpa', 2],
      ['dewF', 1],
    ];
    for (const [key, digits] of fields) {
      const el = card.querySelector(`[data-f="${key}"]`) as HTMLElement | null;
      if (!el) continue;
      const next = s ? fmt(s[key], digits) : '—';
      // Amber tick when a reading actually changes (not on first paint / dropout).
      if (el.textContent !== next && el.textContent !== '—' && next !== '—') {
        el.classList.remove('tick');
        void el.offsetWidth; // reflow so the animation restarts
        el.classList.add('tick');
      }
      el.textContent = next;
    }
  }

  // VPD sparkline from the `spark` history the API ships. Desktop-only (CSS hides
  // it ≤719px). Flatline guard keeps a steady VPD from rendering as edge-hugging jitter.
  function renderSpark(id: string, points: SparkPoint[] | undefined) {
    const line = document.querySelector(
      `.spark-line[data-spark="${id}"]`,
    ) as SVGPolylineElement | null;
    if (!line) return;
    const vals = (points ?? []).map((p) => p.vpd).filter((v) => typeof v === 'number');
    if (vals.length < 2) {
      line.setAttribute('points', '');
      return;
    }
    const W = 120;
    const H = 28;
    const PAD = 2;
    let min = Math.min(...vals);
    let max = Math.max(...vals);
    if (max - min < 0.1) {
      const mid = (min + max) / 2;
      min = mid - 0.05;
      max = mid + 0.05;
    }
    const n = vals.length;
    const pts = vals.map((v, i) => {
      const x = PAD + (i / (n - 1)) * (W - 2 * PAD);
      const y = H - PAD - ((v - min) / (max - min)) * (H - 2 * PAD);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    });
    line.setAttribute('points', pts.join(' '));
  }

  // ===== EQUIPMENT =====
  let equipOpenKey: string | null = null; // survives re-renders so the open row stays open

  function equipRow(item: PublicEquipment, sensors: EquipmentSensors): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'equip-row';
    li.dataset.key = item.key;

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'equip-line';
    btn.setAttribute('aria-expanded', String(equipOpenKey === item.key));

    const dot = document.createElement('span');
    dot.className = `equip-dot is-${item.state}`;
    const name = document.createElement('span');
    name.className = 'equip-name';
    name.textContent = item.label;
    const state = document.createElement('span');
    state.className = `equip-state is-${item.state}`;
    state.textContent = item.state === 'unknown' ? '—' : item.state.toUpperCase();
    const rule = document.createElement('span');
    rule.className = 'equip-rule';
    rule.textContent = ruleLine(item);
    const chev = document.createElement('span');
    chev.className = 'equip-chev';
    chev.setAttribute('aria-hidden', 'true');
    chev.textContent = '▾';
    btn.append(dot, name, state, rule, chev);
    li.append(btn);

    const detail = document.createElement('div');
    detail.className = 'equip-detail';
    detail.hidden = equipOpenKey !== item.key;
    const why = whyLine(item, sensors);
    if (why) {
      const p = document.createElement('p');
      p.className = 'equip-why';
      p.textContent = why;
      detail.append(p);
    }
    const facts = detailLines(item);
    if (facts.length) {
      const ul = document.createElement('ul');
      ul.className = 'equip-facts';
      for (const f of facts) {
        const fi = document.createElement('li');
        fi.textContent = f;
        ul.append(fi);
      }
      detail.append(ul);
    }
    li.append(detail);

    btn.addEventListener('click', () => {
      equipOpenKey = equipOpenKey === item.key ? null : item.key;
      const list = document.getElementById('equip-list');
      if (!list) return;
      for (const row of list.querySelectorAll<HTMLLIElement>('.equip-row')) {
        const open = equipOpenKey != null && row.dataset.key === equipOpenKey;
        row.querySelector('.equip-line')?.setAttribute('aria-expanded', String(open));
        const det = row.querySelector<HTMLElement>('.equip-detail');
        if (det) det.hidden = !open;
      }
    });

    return li;
  }

  function renderEquipment(d: PublicLive) {
    const list = document.getElementById('equip-list');
    if (!list) return;
    if (!d.equipment || d.equipment.length === 0) {
      list.textContent = '';
      const li = document.createElement('li');
      li.className = 'equip-sys';
      li.textContent = 'equipment status unavailable';
      list.append(li);
      return;
    }
    const canopy = d.sensors.canopy;
    const sensors: EquipmentSensors = {
      canopyRh: canopy?.rh ?? null,
      canopyTempF: canopy?.tempF ?? null,
      canopyVpd: canopy?.vpdKpa ?? null,
    };
    list.textContent = '';
    for (const item of d.equipment) list.append(equipRow(item, sensors));
  }

  // ===== NIGHT THEME =====
  function applyPhase(d: PublicLive) {
    const phase = d.lightPhase ?? null;
    const html = document.documentElement;
    if (phase === 'night') html.dataset.growPhase = 'night';
    else delete html.dataset.growPhase; // day / unknown → default palette

    const badge = document.getElementById('grow-phase-badge');
    if (badge) {
      const text = phaseBadge(phase, d.nextPhaseChange ?? null);
      badge.textContent = text ?? '';
      badge.hidden = text == null;
    }
    const camNote = document.getElementById('grow-cam-night');
    if (camNote) camNote.hidden = phase !== 'night';
  }

  // ===== SEASONAL NOTICE =====
  // Compact chip only — never the full curated sentence, never location/temps.
  function applyNotice(d: PublicLive) {
    const badge = document.getElementById('grow-season-badge');
    if (!badge) return;
    const label = noticeLine(d.notice);
    badge.textContent = label ?? '';
    badge.hidden = label == null;
  }

  function fmtAge(sec: number): string {
    if (sec < 60) return `${sec}s`;
    const m = Math.floor(sec / 60);
    if (m < 60) return `${m}m`;
    const h = Math.floor(m / 60);
    return `${h}h ${m % 60}m`;
  }

  function renderUpdated() {
    const el = document.getElementById('grow-updated');
    if (!el) return;
    if (lastTs == null) {
      el.textContent = '';
      return;
    }
    const age = Math.max(0, Math.round((Date.now() - lastTs) / 1000));
    el.textContent = `updated ${fmtAge(age)} ago`;
  }

  async function tick() {
    const root = document.getElementById('grow-root');
    if (!root) return;
    try {
      const res = await fetch('/api/grow/live', { cache: 'no-store' });
      if (!res.ok) throw new Error(String(res.status));
      const d = (await res.json()) as PublicLive;
      failures = 0;
      lastTs = d.ts;
      renderProbe('canopy', d.sensors.canopy);
      renderProbe('lower', d.sensors.lower);
      renderProbe('room', d.sensors.room);
      if (d.spark) {
        renderSpark('canopy', d.spark.canopy);
        renderSpark('lower', d.spark.lower);
        renderSpark('room', d.spark.room);
      }
      renderEquipment(d);
      applyPhase(d);
      applyNotice(d);
      root.classList.remove('offline');
      root.classList.toggle('stale', d.freshness === 'stale');
      if (d.freshness === 'live') setPill('live', 'LIVE');
      else if (d.freshness === 'stale') setPill('stale', 'STALE');
      else setPill('none', 'NO DATA');
    } catch {
      failures += 1;
      if (failures >= 2) {
        setPill('offline', 'OFFLINE');
        root.classList.add('offline');
      }
    }
    renderUpdated();
  }

  function stop() {
    if (timer != null) clearInterval(timer);
    timer = undefined;
  }

  function start() {
    stop();
    void tick();
    timer = window.setInterval(tick, POLL_MS);
  }

  // Live MJPEG camera. The stream never "ends", so 'load' fires on the first frame (hide the
  // overlay) and 'error' fires if it's offline or at the viewer cap (show overlay, retry with a
  // cache-busting param). src is set AFTER the listeners attach so the first event can't be missed.
  let camRetry: number | undefined;
  let camFsCleanup: (() => void) | undefined;
  function setupCam() {
    const cam = document.getElementById('grow-cam') as HTMLImageElement | null;
    const overlay = document.getElementById('grow-cam-offline');
    const loading = document.getElementById('grow-cam-loading');
    if (!cam || !overlay) return;
    cam.addEventListener('load', () => {
      overlay.hidden = true;
      if (loading) loading.hidden = true;
    });
    cam.addEventListener('error', () => {
      // First connect failed (or the feed dropped): drop the spinner, show the retry notice.
      if (loading) loading.hidden = true;
      overlay.hidden = false;
      if (camRetry != null) clearTimeout(camRetry);
      camRetry = window.setTimeout(() => {
        cam.src = `/api/grow/cam/stream?t=${Date.now()}`;
      }, 5000);
    });
    cam.src = '/api/grow/cam/stream';
  }

  // Fullscreen the camera. Native Fullscreen API where available (desktop, Android) — with a
  // best-effort landscape lock on mobile so it auto-rotates to fill the screen. iPhone Safari
  // has no element fullscreen for an <img>, so we fall back to a CSS fixed-overlay that fills
  // the viewport (the user rotates to landscape themselves).
  function setupCamFullscreen() {
    const frame = document.querySelector('.cam-frame') as HTMLElement | null;
    const btn = document.getElementById('grow-cam-fs');
    if (!frame || !btn) return;
    const d = document as any;
    const f = frame as any;

    const nativeOn = () => d.fullscreenElement || d.webkitFullscreenElement;
    const pseudoOn = () => frame.classList.contains('cam-pseudo-fs');

    const lockLandscape = async () => {
      try {
        await (screen.orientation as any)?.lock?.('landscape');
      } catch {
        /* unsupported (iOS) or not permitted — fine */
      }
    };
    const unlockOrientation = () => {
      try {
        (screen.orientation as any)?.unlock?.();
      } catch {
        /* no-op */
      }
    };

    const sync = () => {
      const active = !!nativeOn() || pseudoOn();
      frame.classList.toggle('is-fs', active);
      btn.setAttribute('aria-label', active ? 'Exit fullscreen' : 'Fullscreen camera');
      btn.setAttribute('title', active ? 'Exit fullscreen' : 'Fullscreen');
    };

    async function enter() {
      const req = f.requestFullscreen || f.webkitRequestFullscreen;
      if (req) {
        try {
          await req.call(frame);
          void lockLandscape();
          return;
        } catch {
          /* fall through to the CSS overlay */
        }
      }
      frame.classList.add('cam-pseudo-fs');
      void lockLandscape();
      sync();
    }

    function exit() {
      if (nativeOn()) (d.exitFullscreen || d.webkitExitFullscreen)?.call(document);
      if (pseudoOn()) frame.classList.remove('cam-pseudo-fs');
      unlockOrientation();
      sync();
    }

    btn.addEventListener('click', () => (nativeOn() || pseudoOn() ? exit() : enter()));
    // Esc already exits native fullscreen; handle it for the pseudo-fullscreen overlay too.
    frame.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && pseudoOn()) exit();
    });
    // Document-level listeners outlive the swapped-out DOM, so remove any pair a
    // previous /grow visit registered before adding this visit's — otherwise they
    // accumulate one stale closure per navigation.
    camFsCleanup?.();
    document.addEventListener('fullscreenchange', sync);
    document.addEventListener('webkitfullscreenchange', sync as EventListener);
    camFsCleanup = () => {
      document.removeEventListener('fullscreenchange', sync);
      document.removeEventListener('webkitfullscreenchange', sync as EventListener);
    };
    sync();
  }

  // Tear down camera side effects when leaving /grow: cancel a pending retry (it would
  // otherwise set src on a detached <img>) and drop the document fullscreen listeners.
  function stopCam() {
    if (camRetry != null) {
      clearTimeout(camRetry);
      camRetry = undefined;
    }
    camFsCleanup?.();
    camFsCleanup = undefined;
  }

  // ===== TENT CHATTER (anonymous shoutbox) =====
  interface PublicShout {
    id: number;
    body: string;
    name: string | null;
    created_at: string;
  }

  const CHATTER_POLL_MS = 25_000;
  let chatterTimer: number | undefined;
  let chatterSeen = new Set<number>();

  // IRC-style HH:MM clock (local, 24h). Full timestamp lives in the title tooltip.
  function clockTime(iso: string): string {
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '--:--';
    return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
  }

  // Stable per-nick colour from a warm CRT-phosphor palette (named users pop;
  // anon stays dim). Deterministic hash so the same nick is always the same hue.
  const NICK_COLORS = [
    '#ff8a3d', '#ffb05c', '#e0a83c', '#ff7e6b', '#d99a4e', '#ffcf87', '#f0915e', '#caa46a',
  ];
  function nickColor(name: string): string {
    let h = 0;
    for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
    return NICK_COLORS[h % NICK_COLORS.length];
  }

  function absTime(iso: string): string {
    const d = new Date(iso);
    return isNaN(d.getTime()) ? iso : d.toLocaleString();
  }

  // Build an IRC row "HH:MM <nick> message" with TEXT NODES only — body/name are
  // untrusted, never innerHTML. Nick colour is set inline (works on JS-made nodes).
  function shoutLine(sh: PublicShout, isNew = false): HTMLLIElement {
    const li = document.createElement('li');
    li.className = isNew ? 'chatter-line is-new' : 'chatter-line';
    li.dataset.id = String(sh.id);

    const t = document.createElement('time');
    t.className = 'chatter-time';
    t.dateTime = sh.created_at;
    t.title = absTime(sh.created_at);
    t.textContent = clockTime(sh.created_at);
    li.append(t);

    const nick = sh.name ? sh.name : 'anon';
    const n = document.createElement('span');
    n.className = 'chatter-nick';
    n.textContent = `<${nick}>`;
    n.style.color = sh.name ? nickColor(nick) : 'var(--crt-dim)';
    li.append(n);

    const msg = document.createElement('span');
    msg.className = 'chatter-msg';
    msg.textContent = sh.body;
    li.append(msg);

    return li;
  }

  // Is the log scrolled to (near) the bottom? Used to keep the newest line in view
  // IRC-style without yanking a reader who has scrolled up into history.
  function isNearBottom(el: HTMLElement): boolean {
    return el.scrollHeight - el.scrollTop - el.clientHeight < 48;
  }

  function renderChatter(items: PublicShout[]) {
    const log = document.getElementById('chatter-log');
    if (!log) return;
    // Bottom-anchored like IRC: keep the newest line in view unless the reader has
    // scrolled up into history.
    const pinned = isNearBottom(log);

    if (!items.length) {
      // Show the placeholder only if nothing has ever been rendered — never wipe
      // shouts already on screen (messages don't erase).
      if (!log.querySelector('.chatter-line')) {
        log.textContent = '';
        const li = document.createElement('li');
        li.className = 'chatter-sys';
        li.textContent = '*** channel quiet — say something';
        log.append(li);
      }
      return;
    }

    // Append-only: add new shouts at the bottom and NEVER remove a rendered line, so
    // nothing erases. Dedup by id so polls don't duplicate; role="log" announces only
    // the newly-appended lines. Timestamps are absolute, so old rows never need redraw.
    log.querySelector('.chatter-sys')?.remove();
    // items are newest-first; walk oldest→newest so new lines append at the bottom in order.
    for (let i = items.length - 1; i >= 0; i--) {
      const sh = items[i];
      if (!chatterSeen.has(sh.id)) {
        log.append(shoutLine(sh, true));
        chatterSeen.add(sh.id);
      }
    }

    if (pinned) log.scrollTop = log.scrollHeight;
  }

  async function loadChatter() {
    try {
      const res = await fetch('/api/grow/shoutbox?limit=50', { cache: 'no-store' });
      if (!res.ok) throw new Error(String(res.status));
      renderChatter((await res.json()) as PublicShout[]);
    } catch {
      const log = document.getElementById('chatter-log');
      if (log && !log.querySelector('.chatter-line')) {
        log.textContent = '';
        const li = document.createElement('li');
        li.className = 'chatter-sys';
        li.textContent = '// channel unreachable — retrying';
        log.append(li);
      }
    }
  }

  function setChatterStatus(msg: string, isError = false) {
    const el = document.getElementById('chatter-status');
    if (!el) return;
    el.textContent = msg;
    el.classList.toggle('is-error', isError);
  }

  function setupChatterForm() {
    const form = document.getElementById('chatter-form') as HTMLFormElement | null;
    const body = document.getElementById('chatter-body') as HTMLTextAreaElement | null;
    const name = document.getElementById('chatter-name') as HTMLInputElement | null;
    const hp = document.getElementById('chatter-hp') as HTMLInputElement | null;
    const count = document.getElementById('chatter-count');
    const postBtn = document.getElementById('chatter-post') as HTMLButtonElement | null;
    if (!form || !body || !postBtn) return;

    const updateCount = () => {
      const remaining = 280 - body.value.length;
      if (count) {
        count.textContent = String(remaining);
        count.classList.toggle('is-warn', remaining <= 40 && remaining > 0);
        count.classList.toggle('is-over', remaining < 0);
      }
    };
    body.addEventListener('input', updateCount);
    updateCount();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = body.value.trim();
      if (!text) {
        setChatterStatus('say something first', true);
        return;
      }
      postBtn.disabled = true;
      setChatterStatus('transmitting…');
      try {
        const res = await fetch('/api/grow/shoutbox', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            body: text,
            name: name && name.value.trim() ? name.value.trim() : undefined,
            website: hp ? hp.value : '',
          }),
        });
        if (res.status === 201) {
          const sh = (await res.json()) as PublicShout;
          const log = document.getElementById('chatter-log');
          if (log) {
            log.querySelector('.chatter-sys')?.remove();
            if (!chatterSeen.has(sh.id)) {
              log.append(shoutLine(sh, true));
              chatterSeen.add(sh.id);
            }
            log.scrollTop = log.scrollHeight; // jump to the newest (the poster's own line)
          }
          body.value = '';
          updateCount();
          setChatterStatus('transmitted ✓');
          body.focus(); // poster's own action — keep focus for rapid posting (not focus-stealing)
        } else if (res.status === 429) {
          setChatterStatus('rate limited — slow down a sec', true);
        } else if (res.status === 400) {
          const d = (await res.json().catch(() => ({}))) as { error?: string };
          setChatterStatus(d.error || "that didn't go through", true);
        } else {
          throw new Error(String(res.status));
        }
      } catch {
        setChatterStatus("couldn't send — try again", true);
      } finally {
        postBtn.disabled = false;
      }
    });
  }

  function startChatter() {
    stopChatter();
    void loadChatter();
    chatterTimer = window.setInterval(loadChatter, CHATTER_POLL_MS);
  }

  function stopChatter() {
    if (chatterTimer != null) clearInterval(chatterTimer);
    chatterTimer = undefined;
  }

  // ClientRouter is active: init on every page load, stop when leaving /grow or
  // when the tab is hidden.
  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('grow-root')) {
      // The page DOM (incl. an empty #chatter-log) is rebuilt on every nav, but this
      // Set is module-scoped and survives — so without resetting it, every id is
      // "already seen" and the fresh log never repopulates until a hard reload.
      chatterSeen = new Set();
      equipOpenKey = null;
      start();
      setupCam();
      setupCamFullscreen();
      setupChatterForm();
      startChatter();
    } else {
      stop();
      stopChatter();
      stopCam();
      delete document.documentElement.dataset.growPhase; // night palette must not leak to other pages
    }
  });

  document.addEventListener('visibilitychange', () => {
    if (!document.getElementById('grow-root')) return;
    if (document.hidden) {
      stop();
      stopChatter();
    } else {
      start();
      startChatter();
    }
  });
</script>
