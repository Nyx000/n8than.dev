---
import BaseLayout from '../layouts/BaseLayout.astro';

const probes = [
  { id: 'canopy', label: 'CANOPY', note: 'at the plant tops — drives VPD' },
  { id: 'lower', label: 'LOWER TENT', note: 'under the canopy — gradient sentinel' },
  { id: 'room', label: 'INTAKE AIR', note: 'ambient air feeding the tent' },
];

// The four readouts per card. `key` selects the contextual definition; `aria` names the
// term for screen readers on the ? trigger.
const metrics = [
  { f: 'tempF', unit: '°F', label: 'temp', key: 'temperature', aria: 'temperature' },
  { f: 'rh', unit: '%', label: 'humidity', key: 'humidity', aria: 'humidity' },
  { f: 'vpdKpa', unit: 'kPa', label: 'VPD', key: 'vpd', aria: 'VPD (vapor pressure deficit)' },
  { f: 'dewF', unit: '°F', label: 'dew point', key: 'dewpoint', aria: 'dew point' },
];

// Tooltip copy — same core meaning, but the "why it matters here" is tuned to each zone.
const defs: Record<string, Record<string, string>> = {
  canopy: {
    temperature: 'Air temp at the leaves, where transpiration happens.',
    humidity: 'Relative humidity at the canopy — moisture the air holds vs. its max at this temp.',
    vpd: 'Vapor Pressure Deficit — how "thirsty" the air is at the leaf; it drives transpiration. The zone that matters most.',
    dewpoint:
      'The temp at which canopy air would condense — how close buds are to wet (mold risk).',
  },
  lower: {
    temperature:
      'Air temp beneath the canopy; compared to canopy temp it reveals vertical stratification.',
    humidity: 'RH down low, where moisture pools — usually higher than the canopy.',
    vpd: 'Vapor Pressure Deficit near the floor — a low-zone check on the gradient.',
    dewpoint:
      'Condensation temp in the coldest, dampest zone — the first place to see condensation.',
  },
  room: {
    temperature: 'Temp of the ambient room air being pulled into the tent.',
    humidity: 'RH of the incoming air — the baseline the tent has to correct.',
    vpd: 'Vapor Pressure Deficit of the intake air, before the tent conditions it.',
    dewpoint: 'Condensation temp of the incoming air.',
  },
};
---

<BaseLayout
  title="Grow Tent Telemetry | n8than.dev"
  description="Live environmental telemetry from a self-built, read-only grow tent monitoring stack."
>
  <section class="container" id="grow-root">
    <div class="heading-row">
      <h1 class="section-heading">Grow Tent Telemetry</h1>
      <span id="grow-pill" class="pill">CONNECTING</span>
    </div>
    <p class="intro">
      Live readings from a self-built monitoring stack running on this same server: a controller in
      a grow tent is polled read-only every 10 seconds, logged to Postgres, and streamed here. Three
      probes — canopy, lower tent, and intake air.
      <span id="grow-updated"></span>
    </p>

    <div class="cluster stagger">
      {
        probes.map((p) => (
          <article class="zone" data-probe={p.id}>
            <header class="zone-head">
              <h2 class="probe-name">{p.label}</h2>
              <span class="probe-note">{p.note}</span>
            </header>
            <div class="readout">
              {metrics.map((m) => (
                <div class="metric">
                  <span class="value" data-f={m.f}>
                    —
                  </span>
                  <span class="unit">{m.unit}</span>
                  <span class="label">
                    {m.label}
                    <span class="tip">
                      <button
                        type="button"
                        class="tip-btn"
                        aria-label={`What is ${m.aria}?`}
                        aria-describedby={`tip-${p.id}-${m.key}`}
                      >
                        ?
                      </button>
                      <span class="tip-bubble" role="tooltip" id={`tip-${p.id}-${m.key}`}>
                        {defs[p.id][m.key]}
                      </span>
                    </span>
                  </span>
                </div>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <article class="card cam-card">
      <header class="card-head">
        <h2 class="probe-name">TENT CAMERA</h2>
      </header>
      <div class="cam-frame">
        <img id="grow-cam" class="cam-img" alt="live tent camera" />
        <div id="grow-cam-offline" class="cam-overlay" hidden>camera offline · retrying…</div>
        <button
          id="grow-cam-fs"
          class="cam-fs-btn"
          type="button"
          aria-label="Fullscreen camera"
          title="Fullscreen"
        >
          <svg class="fs-enter" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"
            ></path>
          </svg>
          <svg class="fs-exit" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"
            ></path>
          </svg>
        </button>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: 64rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .heading-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border);
    display: inline-block;
  }

  .pill {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    padding: 0.25em 0.7em;
    border: 1px solid var(--color-muted);
    border-radius: 3px;
    color: var(--color-muted);
  }

  .pill.live {
    border-color: var(--color-accent);
    color: var(--color-accent);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .pill.stale {
    border-color: #c9a227;
    color: #c9a227;
  }

  .pill.offline {
    border-color: #b3404a;
    color: #b3404a;
  }

  @keyframes pulse {
    50% {
      opacity: 0.55;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill.live {
      animation: none;
    }
  }

  .intro {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-top: calc(-0.5 * var(--space-lg));
    margin-bottom: var(--space-lg);
  }

  #grow-updated {
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  /* The instrument cluster. On phones the three zones read as ONE panel — a single
     bordered console with hairline dividers, no inter-card gaps, no graphs — so the
     whole readout sits compact above the camera. At 720px the panel dissolves and each
     zone becomes its own card in a 3-up row. */
  .cluster {
    margin-bottom: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .zone {
    padding: var(--space-md) var(--space-lg);
  }

  .zone + .zone {
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 720px) {
    .cluster {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
      background: transparent;
      border: 0;
      border-radius: 0;
    }

    .zone {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 10px;
      transition: border-color 0.25s ease;
    }

    .zone + .zone {
      border-top: 1px solid var(--color-border);
    }

    .zone:hover {
      border-color: var(--color-accent);
    }
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    transition: border-color 0.25s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
  }

  .card-head,
  .zone-head {
    margin-bottom: var(--space-md);
  }

  .probe-name {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0;
  }

  .probe-note {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .readout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-sm);
  }

  .metric {
    position: relative;
    display: grid;
    grid-template-columns: auto auto;
    grid-template-rows: auto auto;
    align-items: baseline;
    column-gap: 0.25em;
  }

  /* "?" definition tooltip — CSS-first: reveals on hover (desktop), focus (keyboard),
     and tap (the button takes focus on touch, triggering :focus-within). */
  .tip {
    position: static;
    display: inline-flex;
    margin-left: 0.3em;
  }

  .tip-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15em;
    height: 1.15em;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: 50%;
    cursor: help;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .tip-btn:hover,
  .tip-btn:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
    outline: none;
  }

  .tip-bubble {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 5;
    width: max-content;
    max-width: min(240px, 70vw);
    margin-top: 0.4em;
    padding: 0.5em 0.65em;
    font-size: 0.72rem;
    line-height: 1.35;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  /* Right-column metrics: grow the bubble leftward so it stays inside the card. */
  .metric:nth-child(even) .tip-bubble {
    left: auto;
    right: 0;
  }

  .tip:hover .tip-bubble,
  .tip:focus-within .tip-bubble {
    opacity: 1;
    visibility: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .tip-btn,
    .tip-bubble {
      transition: none;
    }
  }

  .value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--color-text);
  }

  .offline .value {
    color: var(--color-muted);
  }

  .unit {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .label {
    grid-column: 1 / -1;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .cam-card {
    margin-bottom: var(--space-lg);
  }

  /* On wide screens, let the camera break out of the 64rem text column to fill more of the
     viewport (e.g. a 1440p display). The page container is viewport-centered, so left:50% +
     translateX(-50%) re-centers a wider card on the viewport; the readouts stay at 64rem. */
  @media (min-width: 1080px) {
    .cam-card {
      position: relative;
      left: 50%;
      width: min(94vw, 1920px);
      transform: translateX(-50%);
    }
  }

  .cam-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-top: var(--space-md);
    background: #0b0b0b;
    border-radius: 8px;
    overflow: hidden;
  }

  .cam-img {
    width: 100%;
    height: 100%;
    /* cover (not contain) so the feed fills the frame edge-to-edge with no letterbox bars —
       the plant becomes the dominant object. Center so the canopy stays in frame. */
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .cam-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: rgba(0, 0, 0, 0.45);
  }

  .cam-overlay[hidden] {
    display: none;
  }

  .cam-fs-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    padding: 0;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 6px;
    cursor: pointer;
    opacity: 0.55;
    transition:
      opacity 0.2s ease,
      background 0.2s ease;
  }

  .cam-frame:hover .cam-fs-btn,
  .cam-fs-btn:focus-visible {
    opacity: 1;
    outline: none;
  }

  .cam-fs-btn:hover {
    background: rgba(0, 0, 0, 0.72);
  }

  .cam-fs-btn svg {
    width: 1.3rem;
    height: 1.3rem;
  }

  .cam-fs-btn .fs-exit {
    display: none;
  }

  .cam-frame.is-fs .cam-fs-btn .fs-enter {
    display: none;
  }

  .cam-frame.is-fs .cam-fs-btn .fs-exit {
    display: inline;
  }

  /* CSS "fill the viewport" fallback for browsers without element fullscreen (iPhone Safari
     on an <img>). Native fullscreen (desktop, Android) is handled by the :fullscreen rules. */
  .cam-frame.cam-pseudo-fs {
    position: fixed;
    inset: 0;
    z-index: 1000;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    margin: 0;
    aspect-ratio: auto;
    border-radius: 0;
  }

  /* In any fullscreen mode, show the whole feed (no crop) and let it fill the screen. */
  .cam-frame.cam-pseudo-fs .cam-img,
  .cam-frame:fullscreen .cam-img,
  .cam-frame:-webkit-full-screen .cam-img {
    object-fit: contain;
  }

  .cam-frame:fullscreen,
  .cam-frame:-webkit-full-screen {
    width: 100vw;
    height: 100vh;
    aspect-ratio: auto;
    border-radius: 0;
  }

  /* Phone: the whole page is one viewport with the camera as the hero. Each zone collapses
     from a 2×2 card into a single tight row — the label on the left, its four readings inline
     — so all three zones stack into a short strip. The intro prose, per-zone notes, and the
     "?" tooltips are desktop-only here; the readings speak for themselves and every saved pixel
     goes to the video. The camera then flexes to claim the rest of the screen. */
  @media (max-width: 719px) {
    #grow-root {
      display: flex;
      flex-direction: column;
      /* Subtract the header + footer so the section ≈ the remaining screen, no long scroll. */
      min-height: calc(100dvh - 11rem);
      padding-top: var(--space-md);
      padding-bottom: var(--space-md);
    }

    .section-heading {
      font-size: 1.5rem;
      margin-bottom: var(--space-sm);
      padding-bottom: var(--space-sm);
    }

    .intro {
      display: none;
    }

    .cluster {
      margin-bottom: var(--space-md);
    }

    /* name | four readings, on one line */
    .zone {
      display: grid;
      grid-template-columns: 4.25rem 1fr;
      align-items: center;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
    }

    .zone-head {
      margin-bottom: 0;
    }

    .probe-note {
      display: none;
    }

    .probe-name {
      font-size: 0.72rem;
      line-height: 1.15;
    }

    .readout {
      grid-template-columns: repeat(4, 1fr);
      gap: 0 var(--space-sm);
    }

    .value {
      font-size: 0.95rem;
    }

    .unit {
      font-size: 0.6rem;
    }

    .label {
      font-size: 0.5rem;
    }

    /* Tooltips are a desktop affordance; on a phone they'd be untappably small and steal room. */
    .tip {
      display: none;
    }

    /* Camera eats the rest of the column — the plant is the hero. */
    .cam-card {
      flex: 1;
      display: flex;
      flex-direction: column;
      margin-bottom: 0;
    }

    .cam-frame {
      flex: 1;
      min-height: 180px;
      aspect-ratio: auto;
    }
  }
</style>

<script>
  interface PublicSensor {
    tempF: number | null;
    rh: number | null;
    vpdKpa: number | null;
    dewF: number | null;
  }
  interface PublicLive {
    ts: number | null;
    freshness: 'live' | 'stale' | 'none';
    sensors: Record<'canopy' | 'lower' | 'room', PublicSensor | null>;
  }

  // 5s matches the API's max-age=5 cache; the sensor cadence is slower (~1/min), so this
  // mainly smooths the "Xs ago" counter and freshness pill rather than fetching newer data.
  const POLL_MS = 5_000;
  let timer: number | undefined;
  let failures = 0;
  let lastTs: number | null = null;

  const fmt = (v: number | null, digits = 1) => (v == null ? '—' : v.toFixed(digits));

  function setPill(state: '' | 'live' | 'stale' | 'offline', text: string) {
    const pill = document.getElementById('grow-pill');
    if (!pill) return;
    pill.className = state ? `pill ${state}` : 'pill';
    pill.textContent = text;
  }

  function renderProbe(id: string, s: PublicSensor | null) {
    const card = document.querySelector(`[data-probe="${id}"]`);
    if (!card) return;
    const fields: Array<[keyof PublicSensor, number]> = [
      ['tempF', 1],
      ['rh', 1],
      ['vpdKpa', 2],
      ['dewF', 1],
    ];
    for (const [key, digits] of fields) {
      const el = card.querySelector(`[data-f="${key}"]`);
      if (el) el.textContent = s ? fmt(s[key], digits) : '—';
    }
  }

  function renderUpdated() {
    const el = document.getElementById('grow-updated');
    if (!el) return;
    if (lastTs == null) {
      el.textContent = '';
      return;
    }
    const age = Math.max(0, Math.round((Date.now() - lastTs) / 1000));
    el.textContent = `Last reading ${age}s ago.`;
  }

  async function tick() {
    const root = document.getElementById('grow-root');
    if (!root) return;
    try {
      const res = await fetch('/api/grow/live', { cache: 'no-store' });
      if (!res.ok) throw new Error(String(res.status));
      const d = (await res.json()) as PublicLive;
      failures = 0;
      lastTs = d.ts;
      renderProbe('canopy', d.sensors.canopy);
      renderProbe('lower', d.sensors.lower);
      renderProbe('room', d.sensors.room);
      root.classList.remove('offline');
      if (d.freshness === 'live') setPill('live', 'LIVE');
      else if (d.freshness === 'stale') setPill('stale', 'STALE');
      else setPill('', 'NO DATA');
    } catch {
      failures += 1;
      if (failures >= 2) {
        setPill('offline', 'OFFLINE');
        root.classList.add('offline');
      }
    }
    renderUpdated();
  }

  function stop() {
    if (timer != null) clearInterval(timer);
    timer = undefined;
  }

  function start() {
    stop();
    void tick();
    timer = window.setInterval(tick, POLL_MS);
  }

  // Live MJPEG camera. The stream never "ends", so 'load' fires on the first frame (hide the
  // overlay) and 'error' fires if it's offline or at the viewer cap (show overlay, retry with a
  // cache-busting param). src is set AFTER the listeners attach so the first event can't be missed.
  let camRetry: number | undefined;
  function setupCam() {
    const cam = document.getElementById('grow-cam') as HTMLImageElement | null;
    const overlay = document.getElementById('grow-cam-offline');
    if (!cam || !overlay) return;
    cam.addEventListener('load', () => {
      overlay.hidden = true;
    });
    cam.addEventListener('error', () => {
      overlay.hidden = false;
      if (camRetry != null) clearTimeout(camRetry);
      camRetry = window.setTimeout(() => {
        cam.src = `/api/grow/cam/stream?t=${Date.now()}`;
      }, 5000);
    });
    cam.src = '/api/grow/cam/stream';
  }

  // Fullscreen the camera. Native Fullscreen API where available (desktop, Android) — with a
  // best-effort landscape lock on mobile so it auto-rotates to fill the screen. iPhone Safari
  // has no element fullscreen for an <img>, so we fall back to a CSS fixed-overlay that fills
  // the viewport (the user rotates to landscape themselves).
  function setupCamFullscreen() {
    const frame = document.querySelector('.cam-frame') as HTMLElement | null;
    const btn = document.getElementById('grow-cam-fs');
    if (!frame || !btn) return;
    const d = document as any;
    const f = frame as any;

    const nativeOn = () => d.fullscreenElement || d.webkitFullscreenElement;
    const pseudoOn = () => frame.classList.contains('cam-pseudo-fs');

    const lockLandscape = async () => {
      try {
        await (screen.orientation as any)?.lock?.('landscape');
      } catch {
        /* unsupported (iOS) or not permitted — fine */
      }
    };
    const unlockOrientation = () => {
      try {
        (screen.orientation as any)?.unlock?.();
      } catch {
        /* no-op */
      }
    };

    const sync = () => {
      const active = !!nativeOn() || pseudoOn();
      frame.classList.toggle('is-fs', active);
      btn.setAttribute('aria-label', active ? 'Exit fullscreen' : 'Fullscreen camera');
      btn.setAttribute('title', active ? 'Exit fullscreen' : 'Fullscreen');
    };

    async function enter() {
      const req = f.requestFullscreen || f.webkitRequestFullscreen;
      if (req) {
        try {
          await req.call(frame);
          void lockLandscape();
          return;
        } catch {
          /* fall through to the CSS overlay */
        }
      }
      frame.classList.add('cam-pseudo-fs');
      void lockLandscape();
      sync();
    }

    function exit() {
      if (nativeOn()) (d.exitFullscreen || d.webkitExitFullscreen)?.call(document);
      if (pseudoOn()) frame.classList.remove('cam-pseudo-fs');
      unlockOrientation();
      sync();
    }

    btn.addEventListener('click', () => (nativeOn() || pseudoOn() ? exit() : enter()));
    // Esc already exits native fullscreen; handle it for the pseudo-fullscreen overlay too.
    frame.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && pseudoOn()) exit();
    });
    document.addEventListener('fullscreenchange', sync);
    document.addEventListener('webkitfullscreenchange', sync as EventListener);
    sync();
  }

  // ClientRouter is active: init on every page load, stop when leaving /grow or
  // when the tab is hidden.
  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('grow-root')) {
      start();
      setupCam();
      setupCamFullscreen();
    } else stop();
  });

  document.addEventListener('visibilitychange', () => {
    if (!document.getElementById('grow-root')) return;
    if (document.hidden) stop();
    else start();
  });
</script>
