---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="n8than.dev" description="Computer scientist, software engineer, and problem solver">
  <section class="hero stagger">
    <h1><span class="name-accent">๖ۣۜNathan</span></h1>
    <div class="cmdline">
      <span class="cmdline-prompt"><span class="cmdline-user">nathan@dev</span><span class="cmdline-path">:~</span>$ </span><span class="cmdline-text"></span><span class="cmdline-cursor" aria-hidden="true"></span>
    </div>
    <svg class="lambda" viewBox="0 0 177 185" aria-hidden="true">
      <path d="M47.243238 12.929372v25.907582h21.335657l8.762858 27.050564-65.14995 100.963372h32.003485l46.48125-68.578894 30.479512 76.960764 48.00522-15.23976-7.61987-23.62162-22.09765 6.85789L87.628587 12.929372H47.243238z"/>
    </svg>
    <nav class="hero-links">
      <a href="/projects"><span class="prompt">&gt;</span> projects</a>
      <a href="/blog"><span class="prompt">&gt;</span> blog</a>
      <a href="/recognition"><span class="prompt">&gt;</span> recognition</a>
      <a href="/about"><span class="prompt">&gt;</span> about</a>
      <div class="nav-divider"></div>
      <a href="https://github.com/Nyx000" target="_blank" rel="noopener noreferrer"><span class="prompt">~</span> github</a>
      <a href="https://www.linkedin.com/in/sd-nhuse/" target="_blank" rel="noopener noreferrer"><span class="prompt">~</span> linkedin</a>
      <a href="mailto:husenathan@gmail.com"><span class="prompt">~</span> email</a>
    </nav>
  </section>
  <script>
    document.addEventListener('astro:page-load', () => {
      const el = document.querySelector('.cmdline-text');
      if (!el) return;

      const commands = [
        'echo "Making computers do what I want."',
        "python3 -c 'print(\"Making computers do what I want.\")'",
        "npx tsx -e 'console.log(\"Making computers do what I want.\")'",
        "dotnet script eval 'Console.WriteLine(\"Making computers do what I want.\")'",
        "g++ -xc++ - <<< 'int main(){puts(\"Making computers do what I want.\");}' && ./a.out",
      ];

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        el.textContent = commands[0];
        return;
      }

      let cmdIndex = 0;
      let firstTypeDone = false;

      function typeCommand(text, onDone) {
        let i = 0;
        const interval = setInterval(() => {
          el.textContent += text[i];
          i++;
          if (i >= text.length) {
            clearInterval(interval);
            if (!firstTypeDone) {
              firstTypeDone = true;
              sessionStorage.setItem('hero-typed', '1');
            }
            onDone();
          }
        }, 95);
      }

      function cycleNext() {
        el.textContent = '';
        setTimeout(() => {
          cmdIndex = (cmdIndex + 1) % commands.length;
          typeCommand(commands[cmdIndex], () => {
            setTimeout(() => {
              cycleNext();
            }, 2000);
          });
        }, 500);
      }

      const played = sessionStorage.getItem('hero-typed');

      if (played) {
        el.textContent = commands[0];
        setTimeout(() => {
          cycleNext();
        }, 2000);
      } else {
        setTimeout(() => {
          typeCommand(commands[0], () => {
            setTimeout(() => {
              cycleNext();
            }, 2000);
          });
        }, 700);
      }
    });
  </script>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex: 1;
    padding: var(--space-lg) var(--space-md);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: var(--space-md);
  }

  .name-accent {
    color: var(--color-accent);
  }

  .cmdline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
    background: rgba(19, 19, 19, 0.5);
    border: 1px solid rgba(30, 30, 34, 0.6);
    padding: 0.4em 0.8em;
    border-radius: 3px;
    animation: revealLeft 0.4s ease-out 0.08s both;
  }

  .cmdline-prompt {
    color: var(--color-muted);
    margin-right: 0.5em;
    opacity: 0.7;
    white-space: pre;
  }

  .cmdline-user {
    color: var(--color-accent);
  }

  .cmdline-path {
    color: #5f87af;
  }

  .cmdline-cursor {
    display: inline-block;
    width: 0.6em;
    height: 1.15em;
    background: rgba(255, 102, 0, 0.45);
    vertical-align: text-bottom;
    animation: blink 0.8s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @keyframes revealLeft {
    from { clip-path: inset(0 100% 0 0); }
    to { clip-path: inset(0 0 0 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cmdline {
      animation: none;
      clip-path: none;
    }
  }

  .lambda {
    width: 22px;
    height: 22px;
    fill: var(--color-accent);
    margin: var(--space-lg) 0;
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .hero-links a {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.2em 0;
    transition: color 0.2s ease;
  }

  .hero-links a:hover {
    color: var(--color-accent);
  }

  .hero-links a:hover .prompt {
    color: var(--color-accent);
  }

  .prompt {
    color: var(--color-accent);
    margin-right: 0.4em;
  }

  .nav-divider {
    width: 24px;
    height: 1px;
    background: var(--color-border);
    margin: 0.3rem 0;
  }

  @media (max-width: 600px) {
    .hero {
      padding: var(--space-md) var(--space-sm);
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-links a {
      font-size: 0.9rem;
    }
  }
</style>
