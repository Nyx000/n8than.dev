---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="n8than.dev" description="Computer scientist, software engineer, and problem solver">
  <section class="hero stagger">
    <h1><span class="name-accent">๖ۣۜNathan</span></h1>
    <p>Making computers do what I want.</p>
    <div class="accent-line"></div>
    <nav class="hero-links">
      <a href="/projects">Projects</a>
      <a href="/journal">Journal</a>
      <a href="/recognition">Recognition</a>
      <a href="/services">Services</a>
      <a href="/about">About</a>
    </nav>
    <div class="contact-links">
      <a href="https://github.com/Nyx000" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/sd-nhuse/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:husenathan@gmail.com">Email</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex: 1;
    padding: var(--space-lg) var(--space-md);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: var(--space-sm);
  }

  .name-accent {
    color: var(--color-accent);
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--color-muted);
    margin-bottom: 0;
  }

  .accent-line {
    width: 48px;
    height: 2px;
    background: var(--color-accent);
    margin: var(--space-lg) auto;
  }

  .hero-links {
    display: flex;
    gap: var(--space-lg);
  }

  .hero-links a {
    border: 1px solid var(--color-muted);
    padding: .5em 1em;
    min-width: 7rem;
    text-align: center;
    border-radius: 9999px;
    color: var(--color-text);
    font-size: 0.9rem;
    text-decoration: none;
    transition:
      border-color 0.25s ease,
      color 0.25s ease;
  }

  .hero-links a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .contact-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .contact-links a {
    color: var(--color-muted);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .contact-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .hero {
      padding: var(--space-md) var(--space-sm);
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-sm);
    }

    .hero-links a {
      min-width: auto;
      padding: .4em .8em;
      font-size: 0.8rem;
    }

    .contact-links {
      margin-top: var(--space-md);
    }
  }
</style>
