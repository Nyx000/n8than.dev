---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="n8than.dev" description="Computer scientist, software engineer, and problem solver">
  <section class="hero stagger">
    <h1><span class="name-accent">๖ۣۜNathan</span></h1>
    <div class="cmdline">
      <span class="cmdline-prompt"><span class="cmdline-user">nathan@dev</span><span class="cmdline-path">:~</span>$ </span><span class="cmdline-text"></span><span class="cmdline-cursor" aria-hidden="true"></span>
    </div>
    <svg class="lambda" viewBox="0 0 177 185" aria-hidden="true">
      <path d="M47.243238 12.929372v25.907582h21.335657l8.762858 27.050564-65.14995 100.963372h32.003485l46.48125-68.578894 30.479512 76.960764 48.00522-15.23976-7.61987-23.62162-22.09765 6.85789L87.628587 12.929372H47.243238z"/>
    </svg>
    <nav class="hero-links">
      <a href="/projects"><span class="prompt">&gt;</span> projects</a>
      <a href="/blog"><span class="prompt">&gt;</span> blog</a>
      <a href="/recognition"><span class="prompt">&gt;</span> recognition</a>
      <a href="/about"><span class="prompt">&gt;</span> about</a>
      <div class="nav-divider"></div>
      <a href="https://github.com/Nyx000" target="_blank" rel="noopener noreferrer"><span class="prompt">~</span> github</a>
      <a href="https://www.linkedin.com/in/sd-nhuse/" target="_blank" rel="noopener noreferrer"><span class="prompt">~</span> linkedin</a>
      <a href="mailto:husenathan@gmail.com"><span class="prompt">~</span> email</a>
    </nav>
  </section>
  <script>
    document.addEventListener('astro:page-load', () => {
      const el = document.querySelector('.cmdline-text');
      if (!el) return;

      const commands = [
        'echo "Making computers do what I want."',
        "python3 -c 'print(\"Making computers do what I want.\")'",
        "npx tsx -e 'console.log(\"Making computers do what I want.\")'",
      ];

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        el.textContent = commands[0];
        return;
      }

      if (window.__cmdlineCleanup) window.__cmdlineCleanup();

      let activeInterval = null;
      let activeTimeout = null;
      let cmdIndex = 0;
      let firstTypeDone = false;

      window.__cmdlineCleanup = () => {
        if (activeInterval) clearInterval(activeInterval);
        if (activeTimeout) clearTimeout(activeTimeout);
      };

      function typeCommand(text, onDone) {
        let i = 0;
        activeInterval = setInterval(() => {
          el.textContent += text[i];
          i++;
          if (i >= text.length) {
            clearInterval(activeInterval);
            activeInterval = null;
            if (!firstTypeDone) {
              firstTypeDone = true;
              sessionStorage.setItem('hero-typed', '1');
            }
            onDone();
          }
        }, 95);
      }

      function cycleNext() {
        el.textContent = '';
        activeTimeout = setTimeout(() => {
          cmdIndex = (cmdIndex + 1) % commands.length;
          typeCommand(commands[cmdIndex], () => {
            activeTimeout = setTimeout(() => {
              cycleNext();
            }, 2000);
          });
        }, 150);
      }

      const cmdline = document.querySelector('.cmdline');
      function scheduleGlitch() {
        const delay = 3000 + Math.random() * 4000;
        setTimeout(() => {
          cmdline.classList.add('glitching');
          setTimeout(() => {
            cmdline.classList.remove('glitching');
            scheduleGlitch();
          }, 200);
        }, delay);
      }
      scheduleGlitch();

      const played = sessionStorage.getItem('hero-typed');
      const initialDelay = played ? 0 : 700;

      activeTimeout = setTimeout(() => {
        typeCommand(commands[0], () => {
          activeTimeout = setTimeout(() => {
            cycleNext();
          }, 2000);
        });
      }, initialDelay);
    });
  </script>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex: 1;
    padding: var(--space-lg) var(--space-md);
    text-shadow:
      2px 0 rgba(255, 40, 40, 0.18),
      -2px 0 rgba(0, 180, 255, 0.18);
  }

  .cmdline {
    position: relative;
    overflow: hidden;
  }

  .cmdline::before,
  .cmdline::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
  }

  .cmdline::before {
    background: repeating-linear-gradient(
      0deg,
      rgba(180, 70, 0, 0.09) 0px,
      transparent 1px,
      transparent 3px
    );
  }

  .cmdline::after {
    background: repeating-linear-gradient(
      0deg,
      rgba(120, 40, 0, 0.06) 0px,
      transparent 1px,
      transparent 3px
    );
  }

  .cmdline.glitching::before {
    opacity: 1;
    animation: glitch-r 200ms steps(6);
  }

  .cmdline.glitching::after {
    opacity: 1;
    animation: glitch-b 200ms steps(6);
  }

  @keyframes glitch-r {
    0% { clip-path: inset(10% -4px 60% 0); transform: translateX(6px); }
    17% { clip-path: inset(65% -4px 5% 0); transform: translateX(-8px); }
    33% { clip-path: inset(25% -4px 45% 0); transform: translateX(10px); }
    50% { clip-path: inset(80% -4px 0% 0); transform: translateX(-5px); }
    67% { clip-path: inset(5% -4px 70% 0); transform: translateX(7px); }
    83% { clip-path: inset(45% -4px 25% 0); transform: translateX(-9px); }
    100% { clip-path: inset(0); transform: none; }
  }

  @keyframes glitch-b {
    0% { clip-path: inset(55% -4px 15% 0); transform: translateX(-7px); }
    17% { clip-path: inset(5% -4px 65% 0); transform: translateX(9px); }
    33% { clip-path: inset(70% -4px 5% 0); transform: translateX(-6px); }
    50% { clip-path: inset(20% -4px 50% 0); transform: translateX(8px); }
    67% { clip-path: inset(50% -4px 20% 0); transform: translateX(-10px); }
    83% { clip-path: inset(85% -4px 0% 0); transform: translateX(5px); }
    100% { clip-path: inset(0); transform: none; }
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: var(--space-md);
  }

  .name-accent {
    color: var(--color-accent);
  }

  .cmdline {
    display: flex;
    align-items: center;
    width: 80ch;
    max-width: 100%;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
    background:
      repeating-linear-gradient(
        0deg,
        rgba(180, 70, 0, 0.03) 0px,
        transparent 1px,
        transparent 3px
      ),
      radial-gradient(ellipse at center, transparent 60%, rgba(0, 0, 0, 0.15) 100%);
    border: 1px solid color-mix(in srgb, var(--color-accent) 4%, transparent);
    padding: 0.4em 0.8em;
    border-radius: 3px;
    box-shadow: inset 0 0 30px rgba(180, 70, 0, 0.03);
  }

  .cmdline-prompt {
    color: var(--color-muted);
    margin-right: 0.5em;
    opacity: 0.7;
    white-space: pre;
  }

  .cmdline-user {
    color: color-mix(in srgb, var(--color-accent) 60%, var(--color-muted));
  }

  .cmdline-path {
    color: color-mix(in srgb, #5f87af 55%, var(--color-muted));
  }

  .cmdline-cursor {
    display: inline-block;
    width: 0.6em;
    height: 1.15em;
    background: rgba(255, 102, 0, 0.30);
    vertical-align: text-bottom;
    animation: blink 0.8s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cmdline-cursor,
    .cmdline.glitching::before,
    .cmdline.glitching::after {
      animation: none;
    }
  }

  .lambda {
    width: 22px;
    height: 22px;
    fill: var(--color-accent);
    margin: var(--space-lg) 0;
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .hero-links a {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.2em 0;
    transition: color 0.2s ease;
  }

  .hero-links a:hover {
    color: var(--color-accent);
  }

  .hero-links a:hover .prompt {
    color: var(--color-accent);
  }

  .prompt {
    color: var(--color-accent);
    margin-right: 0.4em;
  }

  .nav-divider {
    width: 24px;
    height: 1px;
    background: var(--color-border);
    margin: 0.3rem 0;
  }

  @media (max-width: 600px) {
    .hero {
      padding: var(--space-md) var(--space-sm);
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-links a {
      font-size: 0.9rem;
    }
  }
</style>
