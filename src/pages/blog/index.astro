---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostPreview from '../../components/PostPreview.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog | n8than.dev" description="Build notes, starting with the tent.">
  <section class="container stagger">
    <h1 class="section-heading">Blog</h1>
    {
      posts.length > 0 ? (
        <div class="posts">
          {posts.map((post) => (
            <PostPreview
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="empty">
          <p class="empty-cmd">
            <span class="prompt" aria-hidden="true">$</span> ls ./posts
          </p>
          <p class="empty-msg">empty — two entries compiling. check back.</p>
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .posts > :global(article + article) {
    margin-top: var(--space-md);
  }

  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    min-height: 50vh;
    font-family: var(--font-mono);
    text-align: center;
  }

  .empty-cmd {
    margin: 0;
    color: var(--color-text);
  }

  .empty-cmd .prompt {
    margin-right: 0.5em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .empty-msg {
    margin: 0;
    color: var(--color-muted);
  }
</style>
