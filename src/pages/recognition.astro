---
import BaseLayout from '../layouts/BaseLayout.astro';

const testimonials = [
  {
    name: 'Kayla',
    date: 'July 30, 2025',
    category: 'Respect',
    message:
      'Thank you for always going above and beyond!! You are very much appreciated!!',
  },
  {
