const categoryColors: Record<string, string> = {
  Quality: 'var(--color-accent)',
  Respect: '#9b59b6',
  Efficiency: '#27ae60',
  Teamwork: '#3498db',
  Accountability: '#16a085',
};
---

<BaseLayout
  title="Recognition | n8than.dev"
  description="Workplace recognition, testimonials, and awards"
>
  <section class="container stagger">
    <h1 class="section-heading">Recognition</h1>

    <div class="award">
      <div class="award-image">
        <img
          src="/values-in-action-award.jpg"
          alt="2025 Values in Action Honoree certificate — Nathan Huse, Scripps Mercy Hospital San Diego"
          width="970"
          height="830"
          loading="eager"
        />
      </div>
      <div class="award-details">
        <h2>Values in Action Honoree</h2>
        <p class="award-org">Scripps Mercy Hospital San Diego</p>
        <p class="award-year">2025</p>
      </div>
    </div>

    <section class="testimonials">
      <h2>Colleague Testimonials</h2>
      <p class="testimonials-summary">
        <span class="stat">{testimonials.length}</span> recognitions from
        <span class="stat">15+</span> colleagues over
        <span class="stat">4+</span> years
      </p>

      <div class="grid">
        {
          testimonials.map((t) => (
            <article class="card">
              <span
                class="badge"
                style={`--badge-color: ${categoryColors[t.category]}`}
              >
                {t.category}
              </span>
              <p class="card-name">{t.name}</p>
              <time class="card-date">{t.date}</time>
              <p class="card-message">{t.message}</p>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 64rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border);
    display: inline-block;
  }

  /* Award */
  .award {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding: var(--space-lg) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
  }

  .award-image {
    max-width: 26rem;
    width: 100%;
  }

  .award-image img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    display: block;
  }

  .award-details {
    text-align: center;
  }

  .award-details h2 {
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .award-org {
    color: var(--color-text);
    font-size: 1.05rem;
  }

  .award-year {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  /* Testimonials */
  .testimonials {
    margin-top: var(--space-xl);
  }

  .testimonials h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .testimonials-summary {
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
    font-size: 0.95rem;
  }

  .testimonials-summary .stat {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  /* Card */
  .card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    background: var(--color-surface);
    position: relative;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--color-muted);
    transform: translateY(-2px);
  }

  .badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--badge-color);
    border: 1px solid var(--badge-color);
    background: transparent;
  }

  .card-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: 1rem;
    padding-right: 6.5rem;
    margin-bottom: 0.25rem;
  }

  .card-date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }

  .card-message {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .container {
      padding: var(--space-md);
    }

    .award {
      padding: var(--space-lg) var(--space-md);
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .card-name {
      padding-right: 5.5rem;
    }
  }
</style>
