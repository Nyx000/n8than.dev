---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services | n8than.dev" description="Freelance services — resume help, website development, and portfolio creation">
  <section class="container stagger">
    <h1 class="section-heading">Services</h1>
    <p class="intro">Available for freelance work. Here's what I can help with.</p>

    <div class="services-list">
      <article class="service">
        <h2>Resume Help</h2>
        <p>ATS-optimized resumes built to pass automated screening and land interviews. Fast turnaround powered by a CS background and AI-assisted workflow.</p>
      </article>
      <article class="service">
        <h2>Website Development</h2>
        <p>Custom websites built with modern frameworks and clean architecture. Fast, accessible, and designed to perform from day one.</p>
      </article>
      <article class="service">
        <h2>Portfolio Creation</h2>
        <p>Developer and creative portfolios built with modern web technologies like Astro 5. Fast, lightweight, and designed to showcase your work with clarity.</p>
      </article>
    </div>

    <div class="contact">
      <p>Interested? <a href="mailto:husenathan@gmail.com">Get in touch</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border);
    display: inline-block;
  }

  .intro {
    color: var(--color-muted);
    margin-bottom: var(--space-xl);
    line-height: 1.75;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .service h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: var(--space-sm);
  }

  .service p {
    color: var(--color-muted);
    line-height: 1.75;
    margin: 0;
  }

  .contact {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .contact p {
    color: var(--color-muted);
    line-height: 1.75;
  }

  .contact a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact a:hover {
    color: var(--color-accent-hover);
  }
</style>
