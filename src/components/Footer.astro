</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md) var(--space-lg);
    width: 100%;
    max-width: 64rem;
    margin: 0 auto;
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.875rem;
    flex-wrap: wrap;
  }

</style>
