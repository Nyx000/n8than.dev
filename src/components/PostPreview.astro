---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;
---

<article class="card card--link">
  <h2 class="card-title"><a href={'/blog/' + slug}>{title}</a></h2>
  <time datetime={pubDate.toISOString()}>
    {
      pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
    }
  </time>
  <p>{description}</p>
  {
    tags && tags.length > 0 && (
      <ul class="tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</article>

<style>
  /* global .card + .card--link handle surface + border/glow hover (no lift). */
  .card {
    padding: var(--space-md) var(--space-lg);
  }

  .card-title {
    margin: 0 0 var(--space-xs);
    font-size: 1.2rem;
  }

  .card-title a {
    font-family: var(--font-display);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }

  .card-title a:hover {
    color: var(--color-accent);
  }

  time {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  p {
    color: var(--color-text);
    margin: var(--space-sm) 0;
    max-width: 65ch;
  }
</style>
