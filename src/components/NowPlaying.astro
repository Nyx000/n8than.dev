---
// Live "now playing" shell line — REAL content (not aria-hidden like the decorative cmdline
// above it). States: connecting → playing/idle; errors render exactly like idle (silent).
// Click expands the official Spotify embed, which loads ONLY on first expand — zero Spotify
// requests/cookies until the visitor opts in.
// Owner privacy: no live playback position is ever shown (the API never returns one), and
// going idle destroys the embed iframe outright — hiding it alone would leave audio playing.
---

<div class="np" id="np-root">
  <!-- The whole line is the dropdown trigger: spotify glyph + bare `"title" — artist`
       (no text prefix, no separate button — the glyph's breathing glow is the affordance).
       Long titles clip under a right fade mask; hover/focus slides the text left to
       reveal the rest (JS measures the overflow). -->
  <button class="np-line" id="np-toggle" aria-expanded="false" aria-controls="np-panel" aria-label="spotify player" disabled>
    <svg class="np-glyph" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        fill="currentColor"
        d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.299.421-1.02.599-1.56.3z"
      ></path>
    </svg>
    <span class="np-scroll">
      <span class="np-text" id="np-text" aria-live="polite"></span>
    </span>
  </button>
  <div class="np-panel" id="np-panel">
    <!-- Jukebox composes in here from Header (<NowPlaying><Jukebox /></NowPlaying>).
         Owner wants it first: request line on top, player embed below. -->
    <slot />
    <div class="np-embed" id="np-embed"></div>
  </div>
</div>

<script>
  import type { PublicNowPlaying } from '../lib/growtent-public-contract';

  const POLL_MS = 15_000;
  let timer: number | undefined;
  let failures = 0;
  let inflight = false;
  let trackId: string | null = null;
  let expanded = false;
  let iframeCurrent = false; // iframe src matches trackId
  // Click-outside listener lives on `document` (persists across ClientRouter navs),
  // so it must be removed before each re-registration or it would leak duplicates.
  let docClickHandler: ((e: MouseEvent) => void) | null = null;

  const $ = (id: string) => document.getElementById(id);

  // Diff-before-write: aria-live only announces when the string actually changes,
  // so a same-track poll produces zero SR announcements.
  function setText(next: string) {
    const el = $('np-text');
    if (el && el.textContent !== next) el.textContent = next;
  }

  function setIdle() {
    setText(''); // glyph-only when quiet — the muted icon IS the idle state
    // is-idle both restyles the line and (via CSS) hides the empty .np-embed so an
    // open dropdown shows the jukebox only. The toggle stays enabled and the drawer
    // stays open if the visitor had it open — jukebox must be reachable while quiet.
    $('np-root')?.classList.add('is-idle');
    // Owner directive: going idle must silence the embed — remove the iframe outright
    // (hiding keeps its audio alive). Manual visitor collapse still only hides.
    $('np-embed')?.replaceChildren();
    iframeCurrent = false;
    trackId = null;
  }

  function loadEmbed() {
    if (!trackId) return;
    const wrap = $('np-embed');
    if (!wrap) return;
    let iframe = wrap.querySelector('iframe');
    if (!iframe) {
      iframe = document.createElement('iframe');
      iframe.title = 'spotify player';
      iframe.width = '100%';
      // Height is set in CSS (responsive), not here: on touch/narrow the embed renders a taller
      // card that a fixed 152 clips → Spotify draws its own scrollbars. CSS gives mobile the
      // 80px compact strip and desktop the 152px card. This attr is only a pre-CSS fallback.
      iframe.height = '152';
      iframe.style.border = '0';
      iframe.setAttribute('loading', 'lazy');
      iframe.setAttribute('allow', 'encrypted-media; fullscreen');
      wrap.appendChild(iframe);
    }
    iframe.src = `https://open.spotify.com/embed/track/${trackId}?utm_source=generator`;
    iframeCurrent = true;
  }

  function setExpanded(on: boolean) {
    expanded = on;
    const panel = $('np-panel');
    const btn = $('np-toggle');
    panel?.classList.toggle('is-open', on);
    if (btn) btn.setAttribute('aria-expanded', String(on));
    if (on) {
      if (!iframeCurrent) loadEmbed();
    }
  }

  function render(d: PublicNowPlaying) {
    if (!d.isPlaying || !d.track) {
      setIdle();
      return;
    }
    $('np-root')?.classList.remove('is-idle');
    setText(`"${d.track.name.toLowerCase()}" — ${d.track.artists.toLowerCase()}`);
    if (d.track.id !== trackId) {
      trackId = d.track.id;
      iframeCurrent = false;
      if (expanded) loadEmbed(); // track changed while open → swap in place
    }
  }

  async function tick() {
    if (!$('np-root')) return;
    if (inflight) return;
    inflight = true;
    const ctrl = new AbortController();
    const kill = window.setTimeout(() => ctrl.abort(), 10_000);
    try {
      const res = await fetch('/api/spotify/now-playing', {
        cache: 'no-store',
        signal: ctrl.signal,
      });
      if (!res.ok) throw new Error(String(res.status));
      failures = 0;
      render((await res.json()) as PublicNowPlaying);
    } catch {
      failures += 1;
      if (failures >= 2) setIdle(); // silent: errors look exactly like idle
    } finally {
      clearTimeout(kill);
      inflight = false;
    }
  }

  function stop() {
    if (timer != null) clearInterval(timer);
    timer = undefined;
  }
  function start() {
    stop();
    void tick();
    timer = window.setInterval(tick, POLL_MS);
  }

  document.addEventListener('astro:page-load', () => {
    // Remove any click-outside listener from the previous page before we bail or
    // re-register — document persists across ClientRouter navs, its handler doesn't.
    if (docClickHandler) {
      document.removeEventListener('click', docClickHandler);
      docClickHandler = null;
    }
    const root = $('np-root');
    if (!root) {
      stop();
      return;
    }
    // Fresh DOM after a ClientRouter nav — reset module state that mirrors it.
    expanded = false;
    iframeCurrent = false;
    trackId = null;
    failures = 0;
    inflight = false;
    // Enable the toggle now that JS is live — the drawer is reachable immediately
    // (and stays reachable while spotify is quiet), no longer gated on playback.
    ($('np-toggle') as HTMLButtonElement | null)?.removeAttribute('disabled');
    $('np-toggle')?.addEventListener('click', () => setExpanded(!expanded));
    // Hover/focus reveal: when the title is clipped, slide it left just far enough to
    // show the tail (plus the fade-mask width), at a constant px/s so long titles don't
    // whip past. Leave/blur eases it back. Reduced motion keeps the clipped view.
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const slide = () => {
        const t = $('np-text');
        const wrap = t?.parentElement;
        if (!t || !wrap) return;
        const overflow = t.scrollWidth - wrap.clientWidth;
        if (overflow > 4) {
          t.style.transitionDuration = `${Math.max(0.6, overflow / 40)}s`;
          t.style.transform = `translateX(${-overflow}px)`;
        }
      };
      const slideBack = () => {
        const t = $('np-text');
        if (t) {
          t.style.transitionDuration = '0.4s';
          t.style.transform = '';
        }
      };
      const btn = $('np-toggle');
      btn?.addEventListener('mouseenter', slide);
      btn?.addEventListener('mouseleave', slideBack);
      btn?.addEventListener('focus', slide);
      btn?.addEventListener('blur', slideBack);
    }
    root.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && expanded) {
        setExpanded(false);
        ($('np-toggle') as HTMLElement | null)?.focus();
      }
    });
    // Click anywhere outside the widget closes the dropdown. The toggle's own click
    // fires first (bubbling), so opening/closing via the button never self-cancels:
    // on open the target is inside np-root (no close); on close `expanded` is already
    // false here (early return).
    docClickHandler = (e: MouseEvent) => {
      if (!expanded) return;
      const r = $('np-root');
      if (r && !r.contains(e.target as Node)) setExpanded(false);
    };
    document.addEventListener('click', docClickHandler);
    if (!document.hidden) start();
  });

  document.addEventListener('visibilitychange', () => {
    if (!$('np-root')) return;
    if (document.hidden) stop();
    else start();
  });
</script>

<style>
  .np {
    max-width: 100%;
  }

  /* The line IS the button now: reset button chrome, keep the terminal type. Packs right
     inside the stretched grid cell so text can only shrink/ellipsize, never spill left
     over the nav (justify-self: end on the cell caused exactly that overflow). */
  .np-line {
    display: flex;
    justify-content: flex-end; /* pack right inside the stretched grid cell */
    align-items: center;
    gap: 0.55em;
    width: 100%;
    margin: 0;
    padding: 0.15em 0;
    min-width: 0;
    font-family: var(--font-display);
    font-size: 0.85rem; /* fixed header size — no vw clamp; the sizer trick is gone */
    color: var(--color-muted);
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    text-align: right;
  }

  .np-line:disabled {
    cursor: default;
  }

  .np-line:focus-visible {
    outline: 1px solid color-mix(in srgb, var(--color-accent) 50%, transparent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .np-line:hover:not(:disabled) {
    color: var(--color-text);
  }

  /* The spotify glyph is the trigger's face: accent-colored with a breathing glow while
     playing (motion = "live control", static = decoration — that's the no-hover
     clickability affordance), muted and still when idle or before JS wakes up. */
  .np-glyph {
    flex-shrink: 0;
    width: 1.15em;
    height: 1.15em;
    color: var(--color-accent);
    filter: drop-shadow(0 0 4px color-mix(in srgb, var(--color-accent) 45%, transparent));
    animation: np-glyph-breathe 2.6s ease-in-out infinite alternate;
    transition: color var(--dur-fast) ease;
  }

  @keyframes np-glyph-breathe {
    from {
      filter: drop-shadow(0 0 1px color-mix(in srgb, var(--color-accent) 25%, transparent));
    }
    to {
      filter: drop-shadow(0 0 6px color-mix(in srgb, var(--color-accent) 75%, transparent));
    }
  }

  .np-line:hover:not(:disabled) .np-glyph,
  .np-line:focus-visible .np-glyph {
    color: var(--color-accent-hover);
  }

  .np.is-idle .np-glyph,
  .np-line:disabled .np-glyph {
    color: var(--color-muted);
    opacity: 0.7;
    animation: none;
    filter: none;
  }

  /* Clip window for the title. Right-edge fade instead of an ellipsis — the hover slide
     needs the tail to emerge smoothly, and a hard "…" would sit frozen mid-slide. The
     text's own right padding keeps short (unclipped) titles out of the fade zone. */
  .np-scroll {
    flex: 0 1 auto;
    min-width: 0;
    max-width: 26rem;
    overflow: hidden;
    mask-image: linear-gradient(to right, black calc(100% - 14px), transparent);
    -webkit-mask-image: linear-gradient(to right, black calc(100% - 14px), transparent);
  }

  .np-text {
    display: inline-block;
    padding-right: 14px;
    transition-property: transform;
    transition-timing-function: linear;
  }

  /* Dropdown: anchored to .site-header (the nearest positioned ancestor — .hdr-music is
     deliberately not positioned), so top: 100% sits flush under the header's bottom border
     with no air gap; right inset matches the header's padding so the panel's right edge
     lines up with the widget above it. It grows with its content (no panel scrollbar).
     z-index 60 clears the hero grain (#grain, z-index 10) and
     the CRT scanline overlay (body::after, z-index 9). visibility keeps the collapsed
     panel out of the a11y tree and non-interactive; the opacity/transform fade is polish. */
  .np-panel {
    position: absolute;
    top: 100%;
    right: var(--space-lg);
    width: min(420px, calc(100vw - 2 * var(--space-md)));
    /* No max-height/overflow — owner wants zero panel scrollbar; the panel grows with its
       content. The jukebox log keeps its own internal cap, so height stays bounded. */
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-top: none; /* the header's own border-bottom reads as this panel's top edge */
    padding: var(--space-sm) var(--space-md);
    z-index: 60;
    visibility: hidden;
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity var(--dur-fast) ease,
      transform var(--dur-fast) ease,
      visibility 0s linear var(--dur-fast);
  }

  .np-panel.is-open {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--dur-fast) ease,
      transform var(--dur-fast) ease;
  }

  .np-embed {
    margin-top: 0.35em;
  }

  /* Idle: the embed iframe was destroyed (audio silenced), so hide its empty box and let
     the dropdown show the jukebox only. */
  .np.is-idle .np-embed {
    display: none;
  }

  /* :global() because the iframe is created in JS and never gets Astro's scope attribute.
     Height drives the embed's layout: 152 = full horizontal card (desktop), 80 = compact
     strip (mobile). A fixed 152 on touch/narrow renders a taller card that clips → Spotify
     scrollbars; the compact strip fits cleanly down to ~280px. */
  .np-embed :global(iframe) {
    display: block;
    width: 100%;
    /* Cap the card width so it reads as a compact player, not a full-bleed banner on wide/4k
       screens. Stays >300px (Spotify's scrollbar floor); shrinks to 100% on narrow columns. */
    max-width: 420px;
    /* 80px is the card's exact natural height at this width — the full row (art, title,
       progress, controls) fills it with no gap. Taller values leave Spotify's own background
       showing below the card (a white strip); shorter clips it. */
    height: 80px;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .np-panel,
    .np-panel.is-open {
      transition: none;
    }

    /* Keep the static glow (it's the affordance), just stop the breathing and the
       hover slide (the JS also skips registering the slide handlers). */
    .np-glyph {
      animation: none;
    }

    .np-text {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .np-line {
      font-size: 0.8rem;
    }

    /* Stacked header: .hdr-music is a full-width row, so the dropdown spans the header
       edge-to-edge (left/right:0) instead of the capped desktop width. It drops below
       the widget's own row (top:100%), clear of the stacked nav above. */
    .np-panel {
      left: 0;
      right: 0;
      width: auto;
    }
  }
</style>
