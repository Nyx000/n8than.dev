---
// Live "now playing" shell line — REAL content (not aria-hidden like the decorative cmdline
// above it). States: connecting → playing/idle; errors render exactly like idle (silent).
// Click expands the official Spotify embed, which loads ONLY on first expand — zero Spotify
// requests/cookies until the visitor opts in.
// Owner privacy: no live playback position is ever shown (the API never returns one), and
// going idle destroys the embed iframe outright — hiding it alone would leave audio playing.
---

<div class="np" id="np-root">
  <div class="np-grid">
    <p class="np-line">
      <span class="np-prompt" aria-hidden="true">♪</span>
      <span class="np-text" id="np-text" aria-live="polite">spotify ~ connecting…</span>
      <button
        class="np-toggle"
        id="np-toggle"
        aria-expanded="false"
        aria-controls="np-panel"
        disabled
      >
        ▸ player
      </button>
    </p>
    <!-- Invisible sizer: reserves the widest plausible line so state swaps never shift the
         menu below — same trick as .cmdline-sizer. Longer titles ellipsize instead. -->
    <p class="np-line np-sizer" aria-hidden="true">
      <span class="np-prompt">♪</span>
      <span class="np-text"
        >spotify ~ playing "a title about as long as titles sensibly get" — some longer artist name</span
      >
      <button class="np-toggle" tabindex="-1">▸ player</button>
    </p>
  </div>
  <div class="np-panel" id="np-panel">
    <p class="np-privacy" id="np-privacy" hidden>
      # opening spotify's player — this loads their embed and may set spotify cookies
    </p>
    <div class="np-embed" id="np-embed"></div>
  </div>
</div>

<script>
  import type { PublicNowPlaying } from '../lib/growtent-public-contract';

  const POLL_MS = 15_000;
  let timer: number | undefined;
  let failures = 0;
  let inflight = false;
  let trackId: string | null = null;
  let expanded = false;
  let iframeCurrent = false; // iframe src matches trackId
  let privacyShown = false;

  const $ = (id: string) => document.getElementById(id);

  // Diff-before-write: aria-live only announces when the string actually changes,
  // so a same-track poll produces zero SR announcements.
  function setText(next: string) {
    const el = $('np-text');
    if (el && el.textContent !== next) el.textContent = next;
  }

  function setIdle() {
    setText('spotify ~ quiet for now');
    const btn = $('np-toggle') as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    $('np-root')?.classList.add('is-idle');
    if (expanded) setExpanded(false);
    // Owner directive: going idle must silence the embed — remove the iframe outright
    // (hiding keeps its audio alive). Manual visitor collapse still only hides.
    $('np-embed')?.replaceChildren();
    iframeCurrent = false;
    trackId = null;
  }

  function loadEmbed() {
    if (!trackId) return;
    const wrap = $('np-embed');
    if (!wrap) return;
    let iframe = wrap.querySelector('iframe');
    if (!iframe) {
      iframe = document.createElement('iframe');
      iframe.title = 'spotify player';
      iframe.width = '100%';
      // Height is set in CSS (responsive), not here: on touch/narrow the embed renders a taller
      // card that a fixed 152 clips → Spotify draws its own scrollbars. CSS gives mobile the
      // 80px compact strip and desktop the 152px card. This attr is only a pre-CSS fallback.
      iframe.height = '152';
      iframe.style.border = '0';
      iframe.setAttribute('loading', 'lazy');
      iframe.setAttribute('allow', 'encrypted-media; fullscreen');
      wrap.appendChild(iframe);
    }
    iframe.src = `https://open.spotify.com/embed/track/${trackId}?utm_source=generator`;
    iframeCurrent = true;
  }

  function setExpanded(on: boolean) {
    expanded = on;
    const panel = $('np-panel');
    const btn = $('np-toggle');
    panel?.classList.toggle('is-open', on);
    if (btn) {
      btn.setAttribute('aria-expanded', String(on));
      btn.textContent = on ? '▾ close' : '▸ player';
    }
    if (on) {
      if (!privacyShown) {
        const p = $('np-privacy');
        if (p) p.hidden = false;
        privacyShown = true;
      }
      if (!iframeCurrent) loadEmbed();
    }
  }

  function render(d: PublicNowPlaying) {
    if (!d.isPlaying || !d.track) {
      setIdle();
      return;
    }
    $('np-root')?.classList.remove('is-idle');
    setText(`spotify ~ playing "${d.track.name.toLowerCase()}" — ${d.track.artists.toLowerCase()}`);
    const btn = $('np-toggle') as HTMLButtonElement | null;
    if (btn) btn.disabled = false;
    if (d.track.id !== trackId) {
      trackId = d.track.id;
      iframeCurrent = false;
      if (expanded) loadEmbed(); // track changed while open → swap in place
    }
  }

  async function tick() {
    if (!$('np-root')) return;
    if (inflight) return;
    inflight = true;
    const ctrl = new AbortController();
    const kill = window.setTimeout(() => ctrl.abort(), 10_000);
    try {
      const res = await fetch('/api/spotify/now-playing', {
        cache: 'no-store',
        signal: ctrl.signal,
      });
      if (!res.ok) throw new Error(String(res.status));
      failures = 0;
      render((await res.json()) as PublicNowPlaying);
    } catch {
      failures += 1;
      if (failures >= 2) setIdle(); // silent: errors look exactly like idle
    } finally {
      clearTimeout(kill);
      inflight = false;
    }
  }

  function stop() {
    if (timer != null) clearInterval(timer);
    timer = undefined;
  }
  function start() {
    stop();
    void tick();
    timer = window.setInterval(tick, POLL_MS);
  }

  document.addEventListener('astro:page-load', () => {
    const root = $('np-root');
    if (!root) {
      stop();
      return;
    }
    // Fresh DOM after a ClientRouter nav — reset module state that mirrors it.
    expanded = false;
    iframeCurrent = false;
    privacyShown = false;
    trackId = null;
    failures = 0;
    inflight = false;
    $('np-toggle')?.addEventListener('click', () => setExpanded(!expanded));
    root.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && expanded) {
        setExpanded(false);
        ($('np-toggle') as HTMLElement | null)?.focus();
      }
    });
    if (!document.hidden) start();
  });

  document.addEventListener('visibilitychange', () => {
    if (!$('np-root')) return;
    if (document.hidden) stop();
    else start();
  });
</script>

<style>
  .np {
    margin-bottom: var(--space-lg);
    max-width: 100%;
  }

  /* Visible line and invisible sizer share one grid cell (cmdline trick): the box is always
     as wide as the sizer, so connecting → playing → idle never nudges the menu below. */
  .np-grid {
    display: inline-grid;
    max-width: 100%;
  }

  .np-line {
    grid-area: 1 / 1;
    display: flex;
    align-items: center;
    gap: 0.5em;
    margin: 0;
    min-width: 0;
    font-family: var(--font-display);
    font-size: clamp(0.85rem, 1.4vw, 0.95rem);
    color: var(--color-muted);
    white-space: nowrap;
  }

  .np-sizer {
    visibility: hidden;
  }

  .np-prompt {
    color: var(--color-accent);
    opacity: 0.7;
  }

  .np.is-idle .np-prompt {
    color: var(--color-muted);
  }

  .np-text {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .np-toggle {
    flex-shrink: 0;
    font: inherit;
    color: var(--color-accent);
    background: none;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    border-radius: 3px;
    padding: 0.1em 0.5em;
    cursor: pointer;
    transition:
      color var(--dur-fast) ease,
      border-color var(--dur-fast) ease;
  }

  .np-toggle:hover:not(:disabled),
  .np-toggle:focus-visible {
    color: var(--color-accent-hover);
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
  }

  .np-toggle:disabled {
    color: var(--color-muted);
    opacity: 0.4;
    cursor: default;
  }

  /* Expand: animated max-height; visibility keeps collapsed content out of the a11y tree.
     Reduced motion snaps. */
  .np-panel {
    overflow: hidden;
    max-height: 0;
    visibility: hidden;
    transition:
      max-height var(--dur-slow) ease,
      visibility 0s linear var(--dur-slow);
  }

  .np-panel.is-open {
    max-height: 240px;
    visibility: visible;
    transition: max-height var(--dur-slow) ease;
  }

  .np-privacy {
    margin: 0.35em 0 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    opacity: 0.8;
  }

  .np-embed {
    margin-top: 0.35em;
  }

  /* :global() because the iframe is created in JS and never gets Astro's scope attribute.
     Height drives the embed's layout: 152 = full horizontal card (desktop), 80 = compact
     strip (mobile). A fixed 152 on touch/narrow renders a taller card that clips → Spotify
     scrollbars; the compact strip fits cleanly down to ~280px. */
  .np-embed :global(iframe) {
    display: block;
    width: 100%;
    height: 152px;
    border: 0;
  }

  @media (max-width: 640px) {
    .np-embed :global(iframe) {
      height: 80px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .np-panel,
    .np-panel.is-open {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .np-line {
      font-size: 0.8rem;
    }
  }
</style>
