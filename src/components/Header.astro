---
import NowPlaying from './NowPlaying.astro';
import Jukebox from './Jukebox.astro';

const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/recognition', label: 'Recognition' },
  { href: '/about', label: 'About' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header" transition:animate="none">
  <a href="/" class="brand">n8than.dev</a>
  <nav>
    {
      links.map((link) => (
        <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
          {link.label}
        </a>
      ))
    }
  </nav>
  <div class="hdr-music">
    <NowPlaying>
      <Jukebox />
    </NowPlaying>
  </div>
</header>

<style>
  .site-header {
    position: relative; /* dropdown anchor for the header music widget */
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    column-gap: var(--space-lg); /* guarantees space between brand and nav; kills the ~600-700px zero-gap crowding */
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    border-bottom: 1px solid var(--color-border);
  }

  /* Third grid cell (the trailing 1fr): the now-playing line + its dropdown.
     Deliberately NOT position: relative — the .np-panel dropdown anchors to
     .site-header instead, so top: 100% lands flush under the header's bottom
     border (this cell is vertically centered and its bottom sits above the
     border by the header padding). min-width: 0 lets the line ellipsize
     instead of forcing the grid wider. */
  .hdr-music {
    justify-self: end;
    min-width: 0;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 400; /* Share Tech Mono is single-weight; 700 was synthetic bold */
    font-size: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .brand:hover {
    color: var(--color-accent);
  }

  nav {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  nav a {
    color: var(--color-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  nav a:hover {
    color: var(--color-text);
  }

  nav a[aria-current='page'] {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* Shrink the nav before it can crowd the brand, buying room down to the stack point. */
  @media (max-width: 760px) {
    nav a {
      font-size: 0.8rem;
      letter-spacing: 0.06em;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      grid-template-columns: 1fr;
      justify-items: start;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
    }

    nav {
      justify-content: flex-start;
      gap: var(--space-sm);
    }

    /* Stacked mode: the music widget is its own full-width row (last). Stretching
       it to the row width lets the dropdown span the header edge-to-edge via
       left/right:0 (set in NowPlaying's mobile query) without overlapping the nav
       above it. */
    .hdr-music {
      justify-self: stretch;
      width: 100%;
    }
  }
</style>
