---
import type { Project } from '../data/projects';

type Props = Project;

const { title, description, url, tags, expandable, details } = Astro.props;
---

<article class="card">
  <h3>
    {url ? (
      <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
    ) : (
      <span class="title-text">{title}</span>
    )}
  </h3>
  <p>{description}</p>
  <ul class="tags">
    {tags.map((tag) => <li>{tag}</li>)}
  </ul>
  {expandable && details && (
    <button class="expand-toggle" aria-expanded="false">Details ▸</button>
    <div class="details" aria-hidden="true" set:html={details} />
  )}
</article>

<script>
  document.querySelectorAll('.expand-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.card');
      const details = card?.querySelector('.details');
      if (!card || !details) return;

      const isOpen = card.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
      details.setAttribute('aria-hidden', String(!isOpen));
      btn.textContent = isOpen ? 'Details ▾' : 'Details ▸';

      if (isOpen) {
        requestAnimationFrame(() => {
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    });
  });
</script>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255, 102, 0, 0.08);
  }

  .card.open {
    grid-column: 1 / -1;
    transform: none;
    box-shadow: none;
  }

  .card.open:hover {
    transform: none;
  }

  h3 {
    margin-top: 0;
  }

  h3 a {
    font-family: var(--font-display);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h3 a::after {
    content: ' \2192';
    transition: color 0.2s ease;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .title-text {
    font-family: var(--font-display);
    color: var(--color-text);
  }

  p {
    color: var(--color-muted);
    margin: var(--space-sm) 0;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tags li {
    font-size: 0.75rem;
    padding: 0.2em 0.65em;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .expand-toggle {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.75rem;
    padding: 0.3em 0.8em;
    border-radius: 3px;
    cursor: pointer;
    margin-top: var(--space-sm);
    align-self: flex-start;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .expand-toggle:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .expand-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .details {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.4s ease,
      opacity 0.3s ease;
  }

  .card.open .details {
    max-height: 900px;
    opacity: 1;
    overflow: visible;
    margin-top: var(--space-md);
  }

  .details :global(h4) {
    font-family: var(--font-display);
    color: var(--color-accent);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: var(--space-md) 0 var(--space-sm);
  }

  .details :global(.detail-section:first-child h4) {
    margin-top: 0;
  }

  .details :global(p),
  .details :global(li) {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .details :global(code) {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 0.8rem;
    background: none;
    border: none;
    padding: 0;
  }

  .details :global(.pipeline) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .details :global(.stats) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .details :global(.skills-list),
  .details :global(.tech-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .details :global(.skills-list li),
  .details :global(.tech-list li) {
    padding: 0.25em 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .details,
    .expand-toggle {
      transition: none;
    }
  }
</style>
