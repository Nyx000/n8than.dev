---
import type { Project } from '../data/projects';

type Props = Project;

const { title, description, url, tags, expandable, details } = Astro.props;
---

<article class="card">
  <div class="card-summary">
    <h3>
      {url ? (
        <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
      ) : (
        <span class="title-text">{title}</span>
      )}
    </h3>
    <p class="description">{description}</p>
    <div class="card-footer">
      <ul class="tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
      {expandable && details && (
        <button class="details-btn" aria-expanded="false">Details &#9656;</button>
      )}
    </div>
  </div>
  {expandable && details && (
    <div class="card-expand">
      <div class="expand-inner">
        <div class="expand-content" set:html={details} />
      </div>
    </div>
  )}
</article>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.details-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.card');
        if (!card) return;
        const isExpanded = card.classList.toggle('expanded');
        btn.setAttribute('aria-expanded', String(isExpanded));
        btn.innerHTML = isExpanded ? 'Close &#9662;' : 'Details &#9656;';
      });
    });
  });
</script>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(255, 102, 0, 0.08);
  }

  h3 {
    margin-top: 0;
  }

  h3 a {
    font-family: var(--font-display);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h3 a::after {
    content: ' \2192';
    transition: color 0.2s ease;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .title-text {
    font-family: var(--font-display);
    color: var(--color-text);
  }

  .description {
    color: var(--color-muted);
    margin: var(--space-sm) 0;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tags li {
    font-size: 0.75rem;
    padding: 0.25em 0.6em;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .details-btn {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.75rem;
    padding: 0.3em 0.8em;
    border-radius: 3px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .details-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .details-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Expand animation */
  .card-expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }

  .card.expanded .card-expand {
    grid-template-rows: 1fr;
  }

  .expand-inner {
    overflow: hidden;
  }

  .expand-content {
    padding-top: var(--space-md);
    margin-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  /* Detail content styles */
  .expand-content :global(.hook) {
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 var(--space-md);
  }

  .expand-content :global(.highlights) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .expand-content :global(.highlights li) {
    color: var(--color-muted);
    font-size: 0.875rem;
    line-height: 1.55;
    padding-left: 1em;
    position: relative;
  }

  .expand-content :global(.highlights li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 4px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .expand-content :global(.highlights strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .expand-content :global(.stats) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  @media (prefers-reduced-motion: reduce) {
    .card-expand {
      transition: none;
    }
  }
</style>
