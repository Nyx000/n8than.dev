---
import type { Project } from '../data/projects';

type Props = Project;

const { title, description, url, tags, expandable, details } = Astro.props;
---

<div class="card-container">
  <article class="card">
    <div class="card-front">
      <h3>
        {url ? (
          <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
        ) : (
          <span class="title-text">{title}</span>
        )}
      </h3>
      <p>{description}</p>
      <ul class="tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
      {expandable && details && (
        <button class="flip-btn" aria-label="Show details">Details ▸</button>
      )}
    </div>
    {expandable && details && (
      <div class="card-back">
        <div class="back-content" set:html={details} />
        <button class="flip-btn back-btn" aria-label="Go back">&#9666; Back</button>
      </div>
    )}
  </article>
</div>

<script>
  document.querySelectorAll('.flip-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const container = btn.closest('.card-container');
      const card = container?.querySelector('.card');
      if (!card) return;
      card.classList.toggle('flipped');
    });
  });
</script>

<style>
  .card-container {
    perspective: 1000px;
    height: 340px;
  }

  .card {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.5s ease;
  }

  .card.flipped {
    transform: rotateY(180deg);
  }

  .card-front,
  .card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .card-front {
    overflow: hidden;
  }

  .card-container:hover .card-front,
  .card-container:hover .card-back {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(255, 102, 0, 0.08);
  }

  .card-back {
    transform: rotateY(180deg);
    overflow-y: auto;
  }

  /* Scrollbar styling for back face */
  .card-back::-webkit-scrollbar {
    width: 4px;
  }

  .card-back::-webkit-scrollbar-track {
    background: transparent;
  }

  .card-back::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }

  h3 {
    margin-top: 0;
  }

  h3 a {
    font-family: var(--font-display);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h3 a::after {
    content: ' \2192';
    transition: color 0.2s ease;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  .title-text {
    font-family: var(--font-display);
    color: var(--color-text);
  }

  p {
    color: var(--color-muted);
    margin: var(--space-sm) 0;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tags li {
    font-size: 0.75rem;
    padding: 0.25em 0.6em;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }

  .flip-btn {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.75rem;
    padding: 0.3em 0.8em;
    border-radius: 3px;
    cursor: pointer;
    margin-top: var(--space-sm);
    align-self: flex-start;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .flip-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  .flip-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .back-btn {
    margin-top: auto;
    flex-shrink: 0;
  }

  .back-content {
    flex: 1;
    min-height: 0;
  }

  .back-content :global(h4) {
    font-family: var(--font-display);
    color: var(--color-accent);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: var(--space-md) 0 var(--space-sm);
  }

  .back-content :global(.detail-section:first-child h4) {
    margin-top: 0;
  }

  .back-content :global(p),
  .back-content :global(li) {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .back-content :global(code) {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 0.8rem;
    background: none;
    border: none;
    padding: 0;
  }

  .back-content :global(.pipeline) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .back-content :global(.stats) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .back-content :global(.skills-list),
  .back-content :global(.tech-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .back-content :global(.skills-list li),
  .back-content :global(.tech-list li) {
    padding: 0.25em 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .flip-btn {
      transition: none;
    }

    .card.flipped {
      transform: none;
    }

    .card.flipped .card-front {
      opacity: 0;
      visibility: hidden;
    }

    .card-back {
      transform: none;
      opacity: 0;
    }

    .card.flipped .card-back {
      opacity: 1;
    }
  }
</style>
